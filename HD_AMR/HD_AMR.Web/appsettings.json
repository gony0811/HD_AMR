{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "DefaultConnection": "Data Source=hd_amr.db"
  },
  "DwgConversion": {
    "OdaFileConverterPath": "/Applications/ODAFileConverter.app/Contents/MacOS/ODAFileConverter",
    "OutputVersion": "ACAD2018",
    "TimeoutSeconds": 60
  },
  "Amr": {
    "Name": "AMR",
    "IpAddress": "192.168.0.10",
    "Port": 502,
    "SlaveId": 1,
    "ReadTimeoutMs": 3000,
    "WriteTimeoutMs": 3000
  },
  "Cobot": {
    "Name": "Cobot",
    "IpAddress": "192.168.58.2",
    "CommandPort": 20003,
    "RpcPath": "/RPC2",
    "StatePort": 20004,
    "DefaultToolId": 1,
    "DefaultUserId": 0,
    "DefaultVelPct": 20,
    "TimeoutMs": 5000,
    "CommandTimeoutMs": 600000
  },
  "Camera": {
    "Name": "Gemini2",
    "DeviceSerial": null,
    "ColorWidth": 1280,
    "ColorHeight": 720,
    "ColorFps": 15,
    "EnableColor": true,
    "MirrorColor": false,
    "DepthWidth": 640,
    "DepthHeight": 400,
    "DepthFps": 15,
    "EnableDepth": true,
    "IrWidth": 640,
    "IrHeight": 400,
    "IrFps": 15,
    "EnableIr": true,
    "DepthMinMm": 200,
    "DepthMaxMm": 4000,
    "JpegQuality": 75,
    "ReconnectDelayMs": 5000,
    "MjpegFps": 15,
    "FrameWaitTimeoutMs": 2000,
    "FrameStarvationReconnectMs": 4000,
    "DisableDepthNoiseRemoval": true,
    "DisableDepthSoftFilter": true,
    "EnableDeviceFrameSkip": false
  },
  "Vision": {
    "Name": "Vision",
    "ServerHost": "127.0.0.1",
    "Port": 8000,
    "HeartbeatPeriodMs": 5000,
    "ReconnectDelayMs": 3000,
    "MaxReconnectAttempts": 10
  },
  "WeldTracking": {
    "ProfileDirectory": "RoiProfiles",
    "AutoLoadProfile": "default",
    "PitchCorrectionEnabled": true,
    "PitchCorrectionSign": -1,
    "IrHFovDeg": 91.0,
    "ColorHFovDeg": 86.0,
    "DefaultWorkDistanceMm": 500.0
  }
}
