@page "/laser"
@rendermode InteractiveServer
@using HD_AMR.Models
@using HD_AMR.Service
@using HD_AMR.Communication
@implements IDisposable
@inject LaserDisplacementSensorService Svc
@inject CobotService Cobot
@inject LaserHeadCalibrationRoutine Routine

<PageTitle>Laser Displacement Sensor</PageTitle>

<h1 class="page-title">Laser Displacement Sensor</h1>
<p class="page-subtitle">레이저 변위 센서 — EtherNet/IP 통신 연결 및 3채널 거리 측정</p>

<div class="card card-surface mb-3" style="max-width: 720px;">
    <div class="card-body">
        <div class="d-flex align-items-center justify-content-between mb-3">
            <h5 class="card-title mb-0">통신 연결 (EtherNet/IP)</h5>
            <span class="badge @(Svc.IsConnected ? "bg-success" : "bg-secondary")">
                @(Svc.IsConnected ? "연결됨" : "끊김")
            </span>
        </div>

        @* 다른 모듈(AMR/Camera 등)과 동일하게 상시 자동 접속 — 수동 연결/해제 없이 상태만 표시.
           대상 IP/포트는 appsettings 로 설정하며 여기서는 참고용으로만 노출한다. *@
        <div class="text-muted small">대상: @Svc.Settings.IpAddress:@Svc.Settings.Port</div>

        @if (!string.IsNullOrEmpty(Svc.LastError))
        {
            <div class="alert alert-warning mt-3 mb-0 py-2">
                마지막 연결 오류: @Svc.LastError
            </div>
        }
    </div>
</div>

<div class="card card-surface" style="max-width: 720px;">
    <div class="card-body">
        <div class="d-flex align-items-center justify-content-between mb-3">
            <h5 class="card-title mb-0">측정값 (거리)</h5>
            <div class="d-flex gap-2">
                <button class="btn btn-sm btn-outline-primary" @onclick="ZeroSetAll"
                        disabled="@(!Svc.IsConnected)">전체 영점 설정</button>
                <button class="btn btn-sm btn-outline-secondary" @onclick="ZeroResetAll"
                        disabled="@(!Svc.IsConnected)">전체 해제</button>
            </div>
        </div>

        @if (!Svc.IsConnected)
        {
            <div class="text-muted">연결되면 채널별 거리가 실시간으로 표시됩니다.</div>
        }
        else
        {
            <table class="table table-sm align-middle mb-0">
                <thead>
                    <tr>
                        <th style="width: 70px;">채널</th>
                        <th class="text-end">거리</th>
                        <th>상태</th>
                        <th style="width: 190px;">영점</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var r in _readings)
                    {
                        <tr>
                            <td><strong>CH@(r.Channel)</strong></td>
                            <td class="text-end">
                                @* 거리 숫자는 Enabled 여부와 무관하게 항상 표시(범위밖이면 흐리게).
                                   유효성은 옆의 "상태" 배지로 구분한다. *@
                                <span class="fs-5 fw-semibold @(r.Enabled ? "" : "text-muted")">@r.Value.ToString("F3")</span>
                                <span class="text-muted ms-1">@Svc.Settings.MeasurementUnit</span>
                            </td>
                            <td>
                                <span class="badge @(r.Enabled ? "bg-success" : "bg-secondary") me-1">
                                    @(r.Enabled ? "측정중" : "범위밖")
                                </span>
                                @if (r.Error)
                                {
                                    <span class="badge bg-danger me-1">에러</span>
                                }
                                @if (r.Warning)
                                {
                                    <span class="badge bg-warning text-dark me-1">경고</span>
                                }
                                @if (r.High)
                                {
                                    <span class="badge bg-info text-dark me-1">HIGH</span>
                                }
                                @if (r.Low)
                                {
                                    <span class="badge bg-info text-dark me-1">LOW</span>
                                }
                                @if (r.Pass)
                                {
                                    <span class="badge bg-primary me-1">PASS</span>
                                }
                                @if (r.Zeroed)
                                {
                                    <span class="badge bg-dark me-1">영점</span>
                                }
                            </td>
                            <td>
                                <button class="btn btn-sm btn-primary me-1" @onclick="() => ZeroSet(r.Channel)">설정</button>
                                <button class="btn btn-sm btn-outline-secondary" @onclick="() => ZeroReset(r.Channel)">해제</button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>

            @* 삼각형 평면 중심 pose (툴 좌표계). 헤드가 툴에 고정되어 로봇 자세 없이 계산.
               x,y=헤드 XY 평균, z=standoff+거리평균, rx/ry/rz=평면 기울기(Rz=0, 툴축 기준). *@
            <div class="mt-3 pt-3 border-top">
                <div class="d-flex align-items-center justify-content-between mb-2">
                    <h6 class="mb-0">삼각형 평면 중심 (툴 좌표계)</h6>
                    <span class="badge @(_pose.Valid ? "bg-success" : "bg-secondary")">
                        @(_pose.Valid ? "계산됨" : "대기")
                    </span>
                </div>

                @if (_pose.Valid)
                {
                    <div class="row g-2 text-center">
                        <div class="col"><div class="small text-muted">X</div><div class="fw-semibold">@_pose.X.ToString("F3")</div></div>
                        <div class="col"><div class="small text-muted">Y</div><div class="fw-semibold">@_pose.Y.ToString("F3")</div></div>
                        <div class="col"><div class="small text-muted">Z</div><div class="fw-semibold">@_pose.Z.ToString("F3")</div></div>
                        <div class="col"><div class="small text-muted">Rx</div><div class="fw-semibold">@_pose.Rx.ToString("F3")<span class="small text-muted">°</span></div></div>
                        <div class="col"><div class="small text-muted">Ry</div><div class="fw-semibold">@_pose.Ry.ToString("F3")<span class="small text-muted">°</span></div></div>
                    </div>
                    <div class="small text-muted mt-2">
                        위치 mm · 회전 도(ZYX) · 법선(툴): (@_pose.Normal[0].ToString("F4"), @_pose.Normal[1].ToString("F4"), @_pose.Normal[2].ToString("F4"))
                    </div>
                }
                else
                {
                    <div class="text-muted small">@_pose.Note</div>
                }
            </div>

            @* 툴 자세 보정: 측정 평면 기울기(Rx, Ry)를 tool=1 프레임 회전 오프셋으로 실제 로봇에 적용한다.
               위치는 고정, Rz 는 적용하지 않는다(3점 거리로 yaw 미결정). 로봇을 물리적으로 움직이므로
               서보 ON + 연결 상태에서만 활성화하고 저속으로 적용한다. *@
            <div class="mt-3 pt-3 border-top">
                <div class="d-flex align-items-center justify-content-between mb-2">
                    <h6 class="mb-0">툴 자세 보정 (Rx, Ry)</h6>
                    <span class="badge @(Cobot.IsConnected ? "bg-success" : "bg-secondary")">
                        @(Cobot.IsConnected ? "로봇 연결됨" : "로봇 끊김")
                    </span>
                </div>

                @if (_pose.Valid)
                {
                    <div class="row g-2 text-center mb-2" style="max-width: 300px;">
                        <div class="col-6">
                            <div class="small text-muted">적용 Rx</div>
                            <div class="fs-5 fw-semibold">@AppliedRx.ToString("F3")<span class="small text-muted">°</span></div>
                        </div>
                        <div class="col-6">
                            <div class="small text-muted">적용 Ry</div>
                            <div class="fs-5 fw-semibold">@AppliedRy.ToString("F3")<span class="small text-muted">°</span></div>
                        </div>
                    </div>
                }
                else
                {
                    <div class="text-muted small mb-2">평면이 계산되면 적용할 Rx, Ry 가 표시됩니다.</div>
                }

                <div class="d-flex align-items-center gap-2">
                    <label class="small text-muted mb-0">속도(%)</label>
                    <input type="number" class="form-control form-control-sm" style="width: 90px;"
                           min="1" max="30" step="1" @bind="_velPct" />
                    <button class="btn btn-sm btn-warning" @onclick="ApplyCorrectionAsync"
                            disabled="@(!Cobot.IsConnected || !Cobot.IsServoEnabled || !_pose.Valid || _applying || _calibrating)">
                        @if (_applying)
                        {
                            <span class="spinner-border spinner-border-sm me-1" role="status" aria-hidden="true"></span>
                            <span>적용 중…</span>
                        }
                        else
                        {
                            <span>보정 적용</span>
                        }
                    </button>
                    @if (!Cobot.IsServoEnabled)
                    {
                        <span class="small text-muted">서보 ON 필요</span>
                    }
                </div>

                @if (!string.IsNullOrEmpty(_cobotMsg))
                {
                    <div class="alert @(_cobotMsg!.Contains("완료") ? "alert-success" : "alert-warning") mt-2 mb-0 py-2 small">
                        @_cobotMsg
                    </div>
                }
            </div>

            @* 헤드 위치 캘리브레이션(틸트 응답): 로봇이 수평면 위에서 툴프레임 ±θ 회전을 자동 수행,
               각 헤드의 거리 변화 기울기에서 헤드 XY(툴 좌표, appsettings 규약)를 부호 포함 역산한다.
               결과는 표시만 하며 설정 파일에 쓰지 않는다 — JSON 스니펫을 수동 반영 후 앱 재시작. *@
            <details class="mt-3 pt-3 border-top">
                <summary style="cursor: pointer;">
                    <strong>헤드 위치 캘리브레이션</strong>
                    <span class="text-muted small">(틸트 응답 자동측정 — 로봇이 움직입니다)</span>
                </summary>
                <div class="mt-2">
                    <div class="small text-muted mb-2">
                        평평한 면 위에서 실행하세요. '자동 수평'이 켜져 있으면 기울어진 상태에서 시작해도 됩니다 —
                        로봇이 측정값 기반으로 자세를 보정(최대 ±15°×3회)한 뒤 수평에서 최종 산출합니다.
                    </div>

                    <div class="d-flex align-items-center flex-wrap gap-2 mb-2">
                        <label class="small text-muted mb-0">틸트(°)</label>
                        <input type="number" class="form-control form-control-sm" style="width: 80px;"
                               min="0.5" max="5" step="0.5" @bind="_calTiltDeg" disabled="@_calibrating" />
                        <label class="small text-muted mb-0">샘플</label>
                        <input type="number" class="form-control form-control-sm" style="width: 70px;"
                               min="3" max="20" step="1" @bind="_calSamples" disabled="@_calibrating" />
                        <label class="small text-muted mb-0">속도(%)</label>
                        <input type="number" class="form-control form-control-sm" style="width: 80px;"
                               min="1" max="30" step="1" @bind="_calVelPct" disabled="@_calibrating" />
                        <div class="form-check mb-0">
                            <input class="form-check-input" type="checkbox" id="calSignCheck"
                                   @bind="_calSignCheck" disabled="@_calibrating" />
                            <label class="form-check-label small" for="calSignCheck">부호 검증(+Z 2mm)</label>
                        </div>
                        <div class="form-check mb-0">
                            <input class="form-check-input" type="checkbox" id="calAutoLevel"
                                   @bind="_calAutoLevel" disabled="@_calibrating" />
                            <label class="form-check-label small" for="calAutoLevel">자동 수평</label>
                        </div>
                    </div>

                    <div class="d-flex align-items-center gap-2 mb-2">
                        <button class="btn btn-sm btn-warning" @onclick="StartCalibrationAsync"
                                disabled="@(!Svc.IsConnected || !Cobot.IsConnected || !Cobot.IsServoEnabled || !_pose.Valid || _calibrating || _applying)">
                            @if (_calibrating)
                            {
                                <span class="spinner-border spinner-border-sm me-1" role="status" aria-hidden="true"></span>
                                <span>캘리브레이션 중…</span>
                            }
                            else
                            {
                                <span>캘리브레이션 시작</span>
                            }
                        </button>
                        @if (_calibrating)
                        {
                            <button class="btn btn-sm btn-outline-danger" @onclick="AbortCalibration">중단</button>
                        }
                        @if (!Cobot.IsServoEnabled)
                        {
                            <span class="small text-muted">서보 ON 필요</span>
                        }
                    </div>

                    @if (_calLog.Count > 0)
                    {
                        <pre class="small bg-body-secondary p-2 rounded mb-2"
                             style="max-height: 180px; overflow-y: auto; white-space: pre-wrap;">@string.Join("\n", _calLog)</pre>
                    }

                    @if (_calResult is { } cr)
                    {
                        @if (!cr.ReturnedToAnchor)
                        {
                            <div class="alert alert-danger py-2 small mb-2">
                                로봇이 앵커 pose 로 복귀하지 못했습니다 — 위치를 수동 확인하세요.
                            </div>
                        }
                        @if (!cr.Success)
                        {
                            <div class="alert alert-warning py-2 small mb-0">캘리브레이션 실패: @cr.Error</div>
                        }
                        else
                        {
                            <table class="table table-sm align-middle mb-2">
                                <thead>
                                    <tr>
                                        <th>CH</th>
                                        <th class="text-end">현재 X</th>
                                        <th class="text-end">측정 X</th>
                                        <th class="text-end">ΔX</th>
                                        <th class="text-end">현재 Y</th>
                                        <th class="text-end">측정 Y</th>
                                        <th class="text-end">ΔY</th>
                                        <th>신뢰도</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var h in cr.Heads)
                                    {
                                        <tr>
                                            <td><strong>CH@(h.Channel)</strong></td>
                                            <td class="text-end">@h.CurrentX.ToString("F2")</td>
                                            <td class="text-end fw-semibold">@h.MeasuredX.ToString("F2")</td>
                                            <td class="text-end text-muted">@((h.MeasuredX - h.CurrentX).ToString("+0.00;-0.00"))</td>
                                            <td class="text-end">@h.CurrentY.ToString("F2")</td>
                                            <td class="text-end fw-semibold">@h.MeasuredY.ToString("F2")</td>
                                            <td class="text-end text-muted">@((h.MeasuredY - h.CurrentY).ToString("+0.00;-0.00"))</td>
                                            <td>
                                                <span class="badge @(h.Confidence == "양호" ? "bg-success" : h.Confidence == "주의" ? "bg-warning text-dark" : "bg-danger")">
                                                    @h.Confidence
                                                </span>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>

                            <div class="small text-muted mb-2">
                                단위 mm(툴 좌표) · 프로브 @(cr.LevelIterations)회 · 최종 잔여 기울기 @cr.FinalTiltDeg.ToString("F3")°
                                (Rx=@cr.BaselineRxDeg.ToString("F3")°, Ry=@cr.BaselineRyDeg.ToString("F3")°)
                                · 평균거리 @cr.MeanDistanceMm.ToString("F1")mm
                                · 삼각형 면적 @cr.TriangleAreaMm2.ToString("F0")mm²
                                @if (cr.SignCheckPassed)
                                {
                                    <span> · 부호 검증 통과</span>
                                }
                                @if (cr.XAxisFlipped || cr.YAxisFlipped)
                                {
                                    <span class="text-danger"> · 축 반전 발생(X:@cr.XAxisFlipped, Y:@cr.YAxisFlipped)</span>
                                }
                            </div>

                            @foreach (var w in cr.Warnings)
                            {
                                <div class="alert alert-warning py-1 px-2 small mb-2">@w</div>
                            }

                            <div class="small text-muted mb-1">
                                적용: 아래 6줄을 appsettings.json 의 LaserDisplacementSensor 섹션에 덮어쓰고 앱을 재시작하세요.
                            </div>
                            <textarea class="form-control form-control-sm font-monospace" rows="6" readonly
                                      style="font-size: 0.8rem;">@cr.AppSettingsJsonSnippet</textarea>
                        }
                    }
                </div>
            </details>

            @* 진단: 실장비에서 상태 비트 오프셋 확정용. 측정 중일 때 아래 각 상태 byte 의 실제 값을 보고
               어느 byte 의 CH비트가 ON 되는지 확인해 appsettings 의 *ByteOffset 을 확정한다. *@
            <details class="mt-3">
                <summary class="text-muted" style="cursor: pointer;">진단 (상태 오프셋 / Input Assembly 원본)</summary>
                <div class="mt-2">
                    <div class="mb-2 small">
                        <span class="text-muted">측정:</span> byte @Svc.Settings.MeasurementByteOffset
                        (stride @Svc.Settings.MeasurementStride) · ×@Svc.Settings.MeasurementScale
                    </div>
                    <table class="table table-sm mb-2" style="max-width: 360px;">
                        <thead>
                            <tr><th>상태</th><th class="text-end">오프셋</th><th class="text-end">현재 byte 값</th></tr>
                        </thead>
                        <tbody>
                            <tr><td>Enable</td><td class="text-end">byte @Svc.Settings.SensorEnableByteOffset</td><td class="text-end font-monospace">@ByteHex(Svc.Settings.SensorEnableByteOffset)</td></tr>
                            <tr><td>Error</td><td class="text-end">byte @Svc.Settings.SensorErrorByteOffset</td><td class="text-end font-monospace">@ByteHex(Svc.Settings.SensorErrorByteOffset)</td></tr>
                            <tr><td>Warning</td><td class="text-end">byte @Svc.Settings.SensorWarningByteOffset</td><td class="text-end font-monospace">@ByteHex(Svc.Settings.SensorWarningByteOffset)</td></tr>
                            <tr><td>HIGH</td><td class="text-end">byte @Svc.Settings.OutputHighByteOffset</td><td class="text-end font-monospace">@ByteHex(Svc.Settings.OutputHighByteOffset)</td></tr>
                            <tr><td>LOW</td><td class="text-end">byte @Svc.Settings.OutputLowByteOffset</td><td class="text-end font-monospace">@ByteHex(Svc.Settings.OutputLowByteOffset)</td></tr>
                            <tr><td>PASS</td><td class="text-end">byte @Svc.Settings.OutputPassByteOffset</td><td class="text-end font-monospace">@ByteHex(Svc.Settings.OutputPassByteOffset)</td></tr>
                        </tbody>
                    </table>
                    <div class="small text-muted mb-1">Input Assembly (@(_dumpBytes?.Length ?? 0) bytes, hex):</div>
                    <pre class="small bg-body-secondary p-2 rounded" style="white-space: pre-wrap; word-break: break-all;">@_hexDump</pre>
                </div>
            </details>
        }
    </div>
</div>

@code {
    private IReadOnlyList<LaserChannelReading> _readings = Array.Empty<LaserChannelReading>();

    // 삼각형 평면 중심 pose(툴 좌표계 x,y,z,rx,ry,rz). 매 폴링마다 갱신.
    private PlanePose _pose = PlanePose.Invalid("연결 대기 중.");

    // 툴 자세 보정: 측정 평면 기울기(Rx, Ry)를 툴프레임 회전 오프셋으로 적용.
    private double _velPct = 5;        // 보정 이동 속도(%) — 안전 기본 저속.
    private bool _applying;
    private string? _cobotMsg;

    // 실장비 검증 부호: 툴을 +Rx 회전 → 측정 Rx 가 −로 수렴(gain≈−1)이므로 offset=+Rx.
    // 툴을 +Ry 회전 → 측정 Ry 가 +로 발산(gain≈+1)이므로 offset=−Ry(반전).
    private double AppliedRx => _pose.Rx;
    private double AppliedRy => -_pose.Ry;

    // 헤드 위치 캘리브레이션(틸트 응답) 상태.
    private double _calTiltDeg = 2.0;
    private int _calSamples = 5;
    private double _calVelPct = 5;
    private bool _calSignCheck = true;
    private bool _calAutoLevel = true;
    private bool _calibrating;
    private CancellationTokenSource? _calCts;
    private readonly List<string> _calLog = new();
    private LaserHeadCalibrationResult? _calResult;

    // 진단(Input Assembly 원본 hex) 상태.
    private byte[]? _dumpBytes;
    private string _hexDump = "(프레임 없음)";

    private PeriodicTimer? _timer;
    private CancellationTokenSource? _cts;

    protected override void OnInitialized()
    {
        _cts = new CancellationTokenSource();
        _ = RefreshLoopAsync(_cts.Token);
    }

    // 연결 상태일 때 UiRefreshMs 주기로 측정 스냅샷을 갱신한다.
    private async Task RefreshLoopAsync(CancellationToken ct)
    {
        var period = TimeSpan.FromMilliseconds(Math.Max(50, Svc.Settings.UiRefreshMs));
        _timer = new PeriodicTimer(period);
        try
        {
            while (await _timer.WaitForNextTickAsync(ct))
            {
                if (Svc.IsConnected)
                {
                    _readings = Svc.GetReadings();
                    _pose = Svc.GetPlanePose();
                    _dumpBytes = Svc.SnapshotInputAssembly();
                    _hexDump = FormatHex(_dumpBytes);
                    await InvokeAsync(StateHasChanged);
                }
            }
        }
        catch (OperationCanceledException)
        {
            // 페이지 폐기 — 정상 종료.
        }
    }

    // 진단: 주어진 오프셋의 최신 프레임 byte 값을 "0xNN (2진수)" 로. 비트가 어느 채널인지 대조용.
    private string ByteHex(int offset)
    {
        var d = _dumpBytes;
        if (d is null || (uint)offset >= (uint)d.Length) return "—";
        return $"0x{d[offset]:X2} ({Convert.ToString(d[offset], 2).PadLeft(8, '0')})";
    }

    // 바이트 오프셋을 쉽게 대조하도록 16바이트마다 "오프셋: 바이트열" 형식으로 hex 덤프.
    private static string FormatHex(byte[]? data)
    {
        if (data is null || data.Length == 0) return "(프레임 없음)";
        var sb = new System.Text.StringBuilder(data.Length * 3 + data.Length / 16 * 8);
        for (int i = 0; i < data.Length; i += 16)
        {
            sb.Append(i.ToString("D3")).Append(": ");
            for (int j = i; j < i + 16 && j < data.Length; j++)
                sb.Append(data[j].ToString("X2")).Append(' ');
            sb.Append('\n');
        }
        return sb.ToString();
    }

    private void ZeroSet(int ch)
    {
        Svc.ZeroSet(ch);
        _readings = Svc.GetReadings();
    }

    private void ZeroReset(int ch)
    {
        Svc.ZeroReset(ch);
        _readings = Svc.GetReadings();
    }

    private void ZeroSetAll()
    {
        Svc.ZeroSetAll();
        _readings = Svc.GetReadings();
    }

    private void ZeroResetAll()
    {
        Svc.ZeroResetAll();
        _readings = Svc.GetReadings();
    }

    // 측정 평면 기울기(Rx, Ry)를 tool=1 프레임의 회전 오프셋으로 실제 로봇에 적용(자세 보정 이동).
    // 위치는 고정, Rz=0(3점 거리로 yaw 미결정). anchor 는 모션 없이 조회한 베이스 기준 TCP pose.
    private async Task ApplyCorrectionAsync()
    {
        if (_applying) return;
        if (!_pose.Valid)
        {
            _cobotMsg = "평면 계산이 필요합니다.";
            return;
        }

        _applying = true;
        _cobotMsg = null;
        try
        {
            var offset = new[] { 0.0, 0.0, 0.0, AppliedRx, AppliedRy, 0.0 };
            var anchor = await Cobot.Rpc.GetTcpPoseInBaseAsync(1);
            var rc = await Cobot.Rpc.MoveByToolOffsetAsync(anchor, user: 0, offset,
                tool: 1, vel: Math.Clamp(_velPct, 1, 30));

            _cobotMsg = rc == 0
                ? $"보정 적용 완료 (Rx={AppliedRx:0.###}°, Ry={AppliedRy:0.###}°)."
                : $"보정 이동 실패 (rc={rc}){FairinoErrorCodes.Suffix(rc)}.";
        }
        catch (Exception ex)
        {
            _cobotMsg = $"보정 적용 오류: {ex.Message}";
        }
        finally
        {
            _applying = false;
        }
    }

    // 헤드 위치 캘리브레이션 실행. 루틴이 예외 대신 결과 객체를 반환하므로 여기 catch 는 안전망.
    private async Task StartCalibrationAsync()
    {
        if (_calibrating) return;

        _calibrating = true;
        _calResult = null;
        _calLog.Clear();
        _calCts = new CancellationTokenSource();
        try
        {
            var opts = new LaserHeadCalibrationOptions
            {
                TiltDeg = _calTiltDeg,
                SamplesPerPoint = _calSamples,
                VelPct = _calVelPct,
                VerifyReadingSign = _calSignCheck,
                AutoLevel = _calAutoLevel,
            };
            _calResult = await Routine.RunAsync(opts,
                msg => { _calLog.Add(msg); _ = InvokeAsync(StateHasChanged); },
                _calCts.Token);
        }
        catch (Exception ex)
        {
            _calResult = LaserHeadCalibrationResult.Fail($"예기치 못한 오류: {ex.Message}");
        }
        finally
        {
            _calibrating = false;
            _calCts.Dispose();
            _calCts = null;
        }
    }

    private void AbortCalibration() => _calCts?.Cancel();

    public void Dispose()
    {
        _calCts?.Cancel();
        _cts?.Cancel();
        _timer?.Dispose();
        _cts?.Dispose();
    }
}
