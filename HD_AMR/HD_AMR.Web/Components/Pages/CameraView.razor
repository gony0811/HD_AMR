@page "/camera"
@rendermode InteractiveServer
@using HD_AMR.Communication
@using HD_AMR.Service
@inject CameraService Svc
@inject IJSRuntime JS
@implements IDisposable

<PageTitle>Camera</PageTitle>

<h1>Gemini 2 깊이 카메라</h1>

<div class="mb-3">
    <span class="badge @(Svc.IsConnected ? "bg-success" : "bg-secondary")">연결 @(Svc.IsConnected ? "정상" : "끊김")</span>
    <span class="badge @(Svc.IsStreaming ? "bg-success" : "bg-secondary")">스트림 @(Svc.IsStreaming ? "활성" : "정지")</span>
    <span class="text-muted ms-2">
        @Svc.Settings.ColorWidth×@Svc.Settings.ColorHeight @@@Svc.Settings.ColorFps fps
        · 깊이 @Svc.Settings.DepthMinMm~@Svc.Settings.DepthMaxMm mm
        @if (Svc.IsStreaming)
        {
            <span> · 추정 FPS @_estimatedFps.ToString("0.0")</span>
        }
    </span>
</div>

<div class="mb-3">
    <button class="btn btn-success" @onclick="StartStream" disabled="@(_busy || !Svc.IsConnected || Svc.IsStreaming)">시작</button>
    <button class="btn btn-warning" @onclick="StopStream" disabled="@(_busy || !Svc.IsStreaming)">정지</button>
    <button class="btn btn-outline-secondary" @onclick="Reconnect" disabled="@_busy">재연결</button>
</div>

@if (Svc.IsStreaming)
{
    <div class="row g-3">
        <div class="col-md-6">
            <h5 class="text-muted">Color</h5>
            <img src="/camera/color.mjpeg?k=@_streamKey" alt="Color stream"
                 style="width:100%;max-width:640px;border:1px solid #ccc;border-radius:4px" />
        </div>
        <div class="col-md-6">
            <h5 class="text-muted">Depth <span class="text-muted" style="font-size:.8rem">(마우스 올리면 거리 mm 표시)</span></h5>
            <div style="position:relative; display:inline-block; width:100%; max-width:640px">
                <img @ref="_depthImg" src="/camera/depth.mjpeg?k=@_streamKey" alt="Depth stream"
                     style="width:100%;display:block;border:1px solid #ccc;border-radius:4px" />
                <div @ref="_depthLabel"
                     style="display:none;position:absolute;pointer-events:none;padding:2px 6px;background:rgba(0,0,0,.7);color:#fff;font-size:12px;border-radius:3px;white-space:nowrap"></div>
            </div>
        </div>
    </div>
}
else
{
    <div class="alert alert-secondary" style="max-width:760px">
        스트림이 정지 상태입니다. 카메라가 연결된 뒤 <b>시작</b> 버튼을 누르거나, 자동 재연결을 기다리세요.
    </div>
}

@if (!string.IsNullOrEmpty(_message))
{
    <div class="alert @(_isError ? "alert-danger" : "alert-info") mt-3" style="max-width:760px">@_message</div>
}

@code {
    private bool _busy;
    private string? _message;
    private bool _isError;

    // <img> src 의 쿼리스트링. 스트림 시작/재연결 시 키를 갱신해 브라우저가 새 연결을 맺도록.
    private int _streamKey = 1;

    // 추정 FPS — 1초마다 LastFrameAt 누적 카운트로 계산.
    private double _estimatedFps;
    private DateTime _lastSampleAt;
    private DateTime _lastFrameSampleAt;

    private CancellationTokenSource? _cts;

    // Depth hover 프로브용 엘리먼트 참조.
    private ElementReference _depthImg;
    private ElementReference _depthLabel;

    protected override void OnInitialized()
    {
        _cts = new CancellationTokenSource();
        _ = PollLoop(_cts.Token);
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        // 스트리밍 중이면(=Depth <img> 가 렌더된 상태) hover 프로브를 바인딩. 1초마다 StateHasChanged 로
        // 재호출돼도 JS 쪽 _probeInit 가드로 실제 바인딩은 1회만.
        if (Svc.IsStreaming)
        {
            try { await JS.InvokeVoidAsync("hdAmrCamera.initDepthProbe", _depthImg, _depthLabel); }
            catch { /* 엘리먼트 미준비/회로 종료 등 무시 */ }
        }
    }

    private async Task PollLoop(CancellationToken ct)
    {
        try
        {
            using var timer = new PeriodicTimer(TimeSpan.FromSeconds(1));
            while (await timer.WaitForNextTickAsync(ct))
            {
                UpdateFpsEstimate();
                await InvokeAsync(StateHasChanged);
            }
        }
        catch (OperationCanceledException) { }
    }

    private void UpdateFpsEstimate()
    {
        var now = DateTime.UtcNow;
        var last = Svc.LastFrameAt;
        if (_lastSampleAt == default)
        {
            _lastSampleAt = now;
            _lastFrameSampleAt = last;
            return;
        }
        var elapsed = (now - _lastSampleAt).TotalSeconds;
        if (elapsed <= 0.1) return;

        // 직전 샘플 이후 새 프레임이 들어왔으면 시간 차로 FPS 추정. 없으면 0 으로 감쇠.
        if (last > _lastFrameSampleAt)
        {
            _estimatedFps = 1.0 / Math.Max(0.001, (last - _lastFrameSampleAt).TotalSeconds);
            _lastFrameSampleAt = last;
        }
        else
        {
            _estimatedFps *= 0.5; // 감쇠.
        }
        _lastSampleAt = now;
    }

    private async Task StartStream()
        => await Run("스트림 시작", async () => { await Svc.StartStreamAsync(); _streamKey++; });

    private async Task StopStream()
        => await Run("스트림 정지", () => Svc.StopStreamAsync());

    private async Task Reconnect()
        => await Run("재연결", async () =>
        {
            await Svc.StopStreamAsync();
            // 백그라운드 재연결 루프가 5초 안에 다시 연결을 시도한다.
            _streamKey++;
        });

    private async Task Run(string label, Func<Task> action)
    {
        if (_busy) return;
        _busy = true;
        _message = null;
        try
        {
            await action();
            Notify($"{label} 완료", false);
        }
        catch (Exception ex)
        {
            Notify($"{label} 실패: {ex.Message}", true);
        }
        finally
        {
            _busy = false;
        }
    }

    private void Notify(string msg, bool error)
    {
        _message = msg;
        _isError = error;
    }

    public void Dispose()
    {
        _cts?.Cancel();
        _cts?.Dispose();
    }
}
