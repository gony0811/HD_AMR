@page "/teaching"
@rendermode InteractiveServer
@using HD_AMR.Data.Entities
@using HD_AMR.Service
@inject TeachingService Service
@inject CobotService Cobot
@inject ILogger<Teaching> Logger
@implements IDisposable

<PageTitle>Teaching</PageTitle>

<h1 class="page-title">Teaching</h1>

<section class="capture-panel">
    <strong>티칭 위치 (BASE 좌표계 기준)</strong>
    @if (!Cobot.IsConnected)
    {
        <div class="hint">⚠ 코봇 RPC 미연결 — 현재 위치 저장/이동 불가.</div>
    }
    <div class="row g-2 align-items-end mt-1">
        <div class="col-auto">
            <label class="form-label">공구(tool)</label>
            <input class="form-control" type="number" min="0" max="15" style="width:90px"
                   @bind="_runTool" disabled="@_isBusy" />
        </div>
        <div class="col-auto">
            <label class="form-label">속도(%)</label>
            <input class="form-control" type="number" min="1" max="100" style="width:90px"
                   @bind="_vel" disabled="@_isBusy" />
        </div>
        <div class="col-auto">
            <button class="btn btn-danger @(_isBusy ? "btn-lg fw-bold" : "")"
                    @onclick="StopAsync" disabled="@(!_isBusy)">
                ■ 정지 (즉시 멈춤)
            </button>
        </div>
    </div>
    @if (!string.IsNullOrEmpty(_msg))
    {
        <div class="status-message @(_isErr ? "err" : "ok")">@_msg</div>
    }
</section>

<section class="list-section">
    @if (_positions is null)
    {
        <p><em>Loading...</em></p>
    }
    else if (_positions.Count == 0)
    {
        <p>등록된 티칭 위치가 없습니다.</p>
    }
    else
    {
        <table class="segment-table">
            <thead>
                <tr>
                    <th>이름</th>
                    <th>X</th>
                    <th>Y</th>
                    <th>Z</th>
                    <th>RX</th>
                    <th>RY</th>
                    <th>RZ</th>
                    <th>J1</th>
                    <th>J2</th>
                    <th>J3</th>
                    <th>J4</th>
                    <th>J5</th>
                    <th>J6</th>
                    <th>Operate</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var p in _positions)
                {
                    <tr class="@(p.Id == _busyId ? "selected" : "")">
                        <td>@p.Name</td>
                        <td class="num">@Fmt(p.X)</td>
                        <td class="num">@Fmt(p.Y)</td>
                        <td class="num">@Fmt(p.Z)</td>
                        <td class="num">@Fmt(p.Rx)</td>
                        <td class="num">@Fmt(p.Ry)</td>
                        <td class="num">@Fmt(p.Rz)</td>
                        <td class="num">@Fmt(p.J1)</td>
                        <td class="num">@Fmt(p.J2)</td>
                        <td class="num">@Fmt(p.J3)</td>
                        <td class="num">@Fmt(p.J4)</td>
                        <td class="num">@Fmt(p.J5)</td>
                        <td class="num">@Fmt(p.J6)</td>
                        <td class="ops">
                            <button class="btn btn-sm btn-outline-primary" title="현재 로봇 위치를 이 슬롯에 저장"
                                    @onclick="() => CaptureAsync(p.Id)"
                                    disabled="@(!Cobot.IsConnected || _isBusy)">현재 위치 저장</button>
                            <button class="btn btn-sm btn-outline-success" title="저장된 위치로 이동 (MoveL)"
                                    @onclick="() => MoveToAsync(p)"
                                    disabled="@(!Cobot.IsConnected || _isBusy || !p.IsTaught)">이동</button>
                            <button class="btn btn-sm btn-outline-danger" title="저장된 좌표 초기화"
                                    @onclick="() => ClearAsync(p.Id)"
                                    disabled="@(_isBusy || !p.IsTaught)">초기화</button>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }
</section>

@code {
    private List<TeachingPosition>? _positions;
    private int _runTool = 1;
    private int _vel = 20;
    private bool _isBusy;
    private int _busyId = -1;
    private string? _msg;
    private bool _isErr;
    private CancellationTokenSource? _moveCts;

    protected override async Task OnInitializedAsync()
    {
        _positions = await Service.ListAsync();
    }

    private static string Fmt(double? v) => v.HasValue ? v.Value.ToString("0.###") : "-";

    private async Task ReloadAsync() => _positions = await Service.ListAsync();

    private async Task CaptureAsync(int id)
    {
        if (!Cobot.IsConnected) return;
        _isBusy = true;
        _busyId = id;
        _msg = null;
        try
        {
            var pose = await Cobot.Rpc.GetTcpPoseInBaseAsync(_runTool);
            var joints = await Cobot.Rpc.GetActualJointPosAsync();
            await Service.SaveCaptureAsync(id, pose, joints, _runTool);
            await ReloadAsync();
            _isErr = false;
            _msg = "현재 위치를 저장했습니다.";
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Teaching capture failed (id={Id})", id);
            _isErr = true;
            _msg = $"저장 실패: {ex.Message}";
        }
        finally
        {
            _isBusy = false;
            _busyId = -1;
            await InvokeAsync(StateHasChanged);
        }
    }

    private async Task MoveToAsync(TeachingPosition p)
    {
        if (!Cobot.IsConnected || !p.IsTaught) return;
        _isBusy = true;
        _busyId = p.Id;
        _msg = null;
        _moveCts = new CancellationTokenSource();
        try
        {
            var pose = new[] { p.X!.Value, p.Y!.Value, p.Z!.Value, p.Rx!.Value, p.Ry!.Value, p.Rz!.Value };
            var rc = await Cobot.Rpc.MoveLAsync(pose, tool: _runTool, user: 0, vel: _vel, ct: _moveCts.Token);
            _isErr = rc != 0;
            _msg = rc == 0 ? $"'{p.Name}' 위치로 이동 완료." : $"이동 실패 (rc={rc}).";
        }
        catch (OperationCanceledException)
        {
            _isErr = true;
            _msg = "사용자 정지";
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Teaching move failed (id={Id})", p.Id);
            _isErr = true;
            _msg = $"이동 실패: {ex.Message}";
        }
        finally
        {
            _moveCts?.Dispose();
            _moveCts = null;
            _isBusy = false;
            _busyId = -1;
            await InvokeAsync(StateHasChanged);
        }
    }

    private async Task StopAsync()
    {
        _moveCts?.Cancel();
        try
        {
            await Cobot.StopMotionImmediateAsync();
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Teaching stop failed");
        }
    }

    private async Task ClearAsync(int id)
    {
        if (_isBusy) return;
        try
        {
            await Service.ClearAsync(id);
            await ReloadAsync();
            _isErr = false;
            _msg = "저장된 좌표를 초기화했습니다.";
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Teaching clear failed (id={Id})", id);
            _isErr = true;
            _msg = $"초기화 실패: {ex.Message}";
        }
    }

    public void Dispose() => _moveCts?.Dispose();
}
