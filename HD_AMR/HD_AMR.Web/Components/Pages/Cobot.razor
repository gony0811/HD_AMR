    /// <summary>조그 1회 증분 이동(버튼 클릭). 입력한 이동량(mm)/회전량(°)만큼 axis(0기준)를 sign 방향으로 정밀
    /// 이동 후 정지한다. 관절 프레임은 MoveJ(관절각 오프셋, IK 없음 → 특이점 안전), 직교(베이스/툴/작업물)는
    /// MoveL 오프셋(IK 사용, 특이점 근처서 rc=38 가능). Run 게이트에 위임해 rc 보고·직렬화(_busy)를 재사용.</summary>
    // 활성 작업물 좌표계를 베이스(0)로 초기화(무변위 MoveJ). 작업물 좌표계 이동 후 조그가
    // 역기구학 오류를 낼 때 사용. 공구는 현재 조그 공구(_jogTool) 기준으로 맞춘다.
    private async Task ResetToBaseFrame()
        => await Run("활성 좌표계 초기화(베이스)", ct => Svc.Rpc!.ResetActiveFrameAsync(_jogTool, 0, ct));

    // 컨트롤러의 현재 활성 작업물 프레임 번호를 클라이언트 추적값에 수동 반영(실측 조회 미지원 펌웨어용).
    // 앱 재시작 후 콜드스타트 시, 조그/초기화가 FK pose 를 베이스로 변환하도록 사용자가 알려주는 경로.
    private void ApplyAssumedUser()
    {
        Svc.Rpc?.SetAssumedActiveUser(_assumedUser);
        Notify($"컨트롤러 활성 작업물 프레임을 #{_assumedUser}로 설정(클라이언트 추적값). 이제 조그/초기화가 이 값 기준으로 베이스 변환합니다.", false);
    }

    private async Task JogStep(int axis, int sign)
    {
        if (_jogMode != JogMode.Increment) return;   // 연속 모드에선 클릭 무시(포인터 이벤트가 처리)
        if (!Svc.IsConnected) { Notify("연결되지 않았습니다.", true); return; }
        var dis = JogStepDis(axis) * sign;                       // 부호 반영(mm 또는 °)
        var unit = JogAxisIsRotational(axis) ? "°" : "mm";
        var label = $"조그 {JogAxisLabels[axis]}{(sign > 0 ? "+" : "-")} {Math.Abs(dis)}{unit}";
        await Run(label, async ct =>
        {
            if (_jogFrame == JogFrame.Joint)
            {
                // 관절 증분: 현재 관절각에 선택 축 ±dis° 더한 MoveJ (IK 없음 → 특이점 안전).
                var joints = await Svc.Rpc!.GetActualJointPosAsync(ct: ct);
                joints[axis] += dis;
                return await Svc.Rpc!.MoveJAsync(joints, new double[6], tool: _jogTool, vel: _jogVel, ct: ct);
            }
            // 직교 증분: 현재 TCP 앵커에 선택 좌표계 축으로 offset 적용(MoveL). 앵커·이동 공구 동일.
            // 앵커 = 현재 위치이므로 현재 관절각이 곧 그 IK 해다. jointPos로 넘겨 클라이언트 GetInverseKin
            // 호출을 생략한다 — GetInverseKin은 user 파라미터가 없어 컨트롤러 활성 프레임(예: 5)에서
            // 계산돼 역기구학 오류를 내므로, 이를 통째로 회피한다. 오프셋은 컨트롤러가 user 기준으로 적용.
            var curJoints = await Svc.Rpc!.GetActualJointPosAsync(ct: ct);
            var anchor = await Svc.Rpc!.GetTcpPoseInBaseAsync(_jogTool, ct);
            var offset = new double[6];
            offset[axis] = dis;
            int flag = _jogFrame == JogFrame.Tool ? 2 : 1;        // 툴=2, 베이스/작업물=1
            int user = _jogFrame == JogFrame.Workpiece ? _jogUser : 0;
            return await Svc.Rpc!.MoveLAsync(anchor, jointPos: curJoints, tool: _jogTool, user: user,
                                             vel: _jogVel, offsetFlag: flag, offsetPos: offset, ct: ct);
        });
    }

    /// <summary>누름 연속 조그 시작(포인터 다운). Hold 모드에서만 동작. StartJOG는 논블로킹이라 Run 게이트를
    /// 쓰지 않고(매 프레스 완료 토스트 방지), maxDis(연속 상한)까지 이동 후 자동 정지한다.</summary>
    private async Task JogHoldStart(int axis, int sign)
    {
        if (_jogMode != JogMode.Hold) return;
        if (!Svc.IsConnected || _busy || _holding) return;
        _holding = true;
        _holdFrame = _jogFrame;
        var max = JogAxisIsRotational(axis) ? _jogHoldMaxDeg : _jogHoldMaxMm;
        try
        {
            var rc = await Svc.Rpc!.StartJogAsync(_jogFrame, axis + 1, sign > 0 ? 1 : 0, max, _jogVel);
            if (rc != 0)
            {
                _holding = false;
                Notify($"연속 조그 시작 실패 (rc={rc}){FairinoErrorCodes.Suffix(rc)}", true);
            }
        }
        catch (Exception ex)
        {
            _holding = false;
            Notify($"연속 조그 시작 실패: {ex.Message}", true);
        }
    }

    /// <summary>누름 연속 조그 정지(포인터 업/이탈/취소). 시작 시 프레임(_holdFrame)의 StopJOG를 보낸다.</summary>
    private async Task JogHoldStop()
    {
        if (!_holding) return;
        var frame = _holdFrame;
        _holding = false;
        try
        {
            await Svc.StopJogAsync(frame);
        }
        catch (Exception ex)
        {
            Notify($"연속 조그 정지 실패: {ex.Message}", true);
        }
    }

    /// <summary>긴급 정지: 진행 중인 명령을 취소하고 즉시 StopMotion 전송(세마포어 우회).</summary>
    private async Task EmergencyStop()
    {
        _opCts?.Cancel();   // 진행 중 명령의 클라이언트 대기/후속 호출 즉시 중단
        _holding = false;   // 연속 조그 상태 해제(ImmStopJOG가 실제 정지)
        try
        {
            await Svc.ImmStopJogImmediateAsync();   // 진행 중 조그 즉시 정지(ImmStopJOG)
            var rc = await Svc.StopMotionImmediateAsync();
            Notify($"긴급 정지 (rc={rc}){FairinoErrorCodes.Suffix(rc)}", rc != 0);
        }
        catch (Exception ex)
        {
            Notify($"긴급 정지 실패: {ex.Message}", true);
        }
    }

