    private const string ClrX = "#F08080";  // X/RX 빨강
    private const string ClrY = "#7EC850";  // Y/RY 초록
    private const string ClrZ = "#5B9BD5";  // Z/RZ 파랑
    private record JogArrow(int Axis, int Sign, string Dir, string Color, string Label, double Cx, double Cy, double Scale);
    private static readonly JogArrow[] PositionArrows =
    {
        new(2, +1, "up",    ClrZ, "Z+", 52, 60, 1.2),
        new(2, -1, "down",  ClrZ, "Z−", 148, 60, 1.2),
        new(0, -1, "up",    ClrX, "X−", 100, 139, 1.0),
        new(0, +1, "down",  ClrX, "X+", 100, 221, 1.0),
        new(1, -1, "left",  ClrY, "Y−", 50, 180, 1.0),
        new(1, +1, "right", ClrY, "Y+", 150, 180, 1.0),
    };
    private static readonly JogArrow[] OrientationArrows =
    {
        new(4, -1, "up",    ClrY, "RY−", 100, 149, 1.0),
        new(4, +1, "down",  ClrY, "RY+", 100, 231, 1.0),
        new(3, +1, "left",  ClrX, "RX+", 50, 190, 1.0),
        new(3, -1, "right", ClrX, "RX−", 150, 190, 1.0),
    };
    // RZ 곡선 아치(파랑) — 상단 무지개, 좌=RZ+, 우=RZ−. 아치 + 화살촉.
    private const string RzArcLeftD  = "M 100 40 A 84 84 0 0 0 16 124";
    private const string RzArcRightD = "M 100 40 A 84 84 0 0 1 184 124";
    private const string RzHeadLeft  = "1,116 31,116 16,150";
    private const string RzHeadRight = "169,116 199,116 184,150";

    private static string N(double v) => v.ToString("0.#", System.Globalization.CultureInfo.InvariantCulture);

    // '위' 화살표(뚱뚱한 블록: 사각 꼬리 + 넓은 삼각 머리) 7점을 방향별 회전·스케일해 polygon points 생성.
    private static string ArrowPoints(string dir, double cx, double cy, double scale)
    {
        (double x, double y)[] up =
        {
            (0, -32), (28, -4), (12, -4), (12, 32), (-12, 32), (-12, -4), (-28, -4),
        };
        double ang = dir switch { "down" => 180.0, "left" => 270.0, "right" => 90.0, _ => 0.0 };
        double r = ang * Math.PI / 180.0, c = Math.Cos(r), s = Math.Sin(r);
        var sb = new System.Text.StringBuilder();
        foreach (var (x, y) in up)
        {
            double sx = x * scale, sy = y * scale;
            double rx = sx * c - sy * s, ry = sx * s + sy * c;
            sb.Append(N(cx + rx)).Append(',').Append(N(cy + ry)).Append(' ');
        }
        return sb.ToString().TrimEnd();
    }

