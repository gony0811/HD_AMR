    private async Task Run(string label, Func<CancellationToken, Task<int>> action)
    {
        if (_busy) return;
        _busy = true;
        _message = null;
        _opCts?.Dispose();
        _opCts = new CancellationTokenSource();
        var ct = _opCts.Token;
        try
        {
            var rc = await action(ct);
            Notify($"{label} 완료 (rc={rc}){FairinoErrorCodes.Suffix(rc)}", rc != 0);
        }
        catch (OperationCanceledException)
        {
            Notify($"{label} 취소됨 (긴급 정지)", true);
        }
        catch (Exception ex)
        {
            Notify($"{label} 실패: {ex.Message}", true);
        }
        finally
        {
            _busy = false;
        }
    }

    private void Notify(string msg, bool error)
    {
        _message = msg;
        _isError = error;
    }

    public void Dispose()
    {
        // 파괴 시 진행 중일 수 있는 증분 이동(MoveL/MoveJ)·연속 조그(StartJOG)를 best-effort 정지.
        if (_holding && Svc.IsConnected) _ = Svc.ImmStopJogImmediateAsync();
        _holding = false;
        if (Svc.IsConnected) _ = Svc.StopMotionImmediateAsync();
        _cts?.Cancel();
        _cts?.Dispose();
        _opCts?.Cancel();
        _opCts?.Dispose();
    }
}
