@page "/cobot"
@rendermode InteractiveServer
@using HD_AMR.Communication
@using HD_AMR.Service
@inject CobotService Svc
@implements IDisposable

<PageTitle>Cobot</PageTitle>

<h1 class="page-title">코봇</h1>

<div class="estop-bar">
    <button class="btn @(Svc.IsServoEnabled ? "btn-success" : "btn-outline-secondary")"
            @onclick="ToggleServo" disabled="@(!Svc.IsConnected)">
        @(Svc.IsServoEnabled ? "서보 ON" : "서보 OFF")
    </button>
    <button class="btn btn-danger estop-btn" @onclick="EmergencyStop" disabled="@(!Svc.IsConnected)">
        ■ 긴급 정지 (E-STOP)
    </button>
    <button class="btn btn-outline-warning" @onclick="ResetError" disabled="@(_busy || !Svc.IsConnected)">
        오류 해제 (Reset Error)
    </button>
    <span class="estop-hint">동작 중 즉시 정지하고 진행 중인 명령을 종료합니다. 오류(errcode 14 등) 발생 시 '오류 해제' 후 재시도하세요.</span>
</div>

<div class="card-surface">

<div class="mb-3">
    <span class="badge @(Svc.IsConnected ? "bg-success" : "bg-secondary")">명령 @(Svc.IsConnected ? "연결됨" : "끊김")</span>
    <span class="badge @(Svc.IsStateConnected ? "bg-success" : "bg-secondary")">상태 @(Svc.IsStateConnected ? "수신중" : "끊김")</span>
    @if (Svc.State is { } fs)
    {
        <span class="badge bg-info" title="상태 패킷(20004)에서 읽은 컨트롤러 현재 활성 좌표계">
            활성 툴 #@fs.Tool / 작업물 #@fs.User
        </span>
    }
    @if (Svc.State is { ErrorCode: not 0 } st)
    {
        <span class="badge bg-danger">오류 코드 @st.ErrorCode — '오류 해제' 필요</span>
    }
</div>

    <p class="mb-2">실시간 상태:
        <span class="badge @(Svc.IsStateConnected ? "bg-success" : "bg-secondary")">
            @(Svc.IsStateConnected ? "수신중" : "미수신")
        </span>
    </p>

    <hr />
    <h4>좌표계 변경</h4>
    <div class="row g-2" style="max-width:760px">
        <div class="col-auto">
            <label class="form-label">번호(id)</label>
            <input class="form-control" type="number" @bind="_frameId" style="width:90px" />
        </div>
        @for (int i = 0; i < 6; i++)
        {
            var idx = i;
            <div class="col-auto">
                <label class="form-label">@PoseLabels[idx]</label>
                <input class="form-control" type="number" step="0.1" @bind="_frame[idx]" style="width:100px" />
            </div>
        }
    </div>
    <div class="mt-2">
        <button class="btn btn-outline-secondary" @onclick="LoadToolCoord" disabled="@(_busy || !Svc.IsConnected)">공구 불러오기</button>
        <button class="btn btn-outline-secondary" @onclick="LoadWObjCoord" disabled="@(_busy || !Svc.IsConnected)">작업물 불러오기</button>
        <span class="mx-2">|</span>
        <button class="btn btn-primary" @onclick="SetToolCoord" disabled="@_busy">공구 좌표계 설정 (SetToolCoord)</button>
        <button class="btn btn-outline-primary" @onclick="SetWObjCoord" disabled="@_busy">사용자 좌표계 설정 (SetWObjCoord)</button>
    </div>
    <p class="text-muted mt-1" style="max-width:760px"><small>⚠ 설정 전에 반드시 '불러오기'로 현재 값을 확인·수정하세요. 빈 값(0)으로 설정하면 기존 좌표계가 0으로 덮어써집니다.</small></p>

    <hr />
    <h4>이동 (BASE 좌표계 기준)</h4>
    <div class="row g-2" style="max-width:760px">
        @for (int i = 0; i < 6; i++)
        {
            var idx = i;
            <div class="col-auto">
                <label class="form-label">@PoseLabels[idx]</label>
                <input class="form-control" type="number" step="0.1" @bind="_target[idx]" style="width:100px" />
            </div>
        }
    </div>
    <div class="row g-2 mt-1 align-items-end" style="max-width:900px">
        <div class="col-auto">
            <label class="form-label">공구(tool)</label>
            <input class="form-control" type="number" min="0" max="15" @bind="_moveTool" style="width:90px" />
        </div>
        <div class="col-auto">
            <label class="form-label">속도(%) : @_vel</label>
            <input type="range" class="form-range" min="1" max="100" @bind="_vel" style="width:160px" />
        </div>
        <div class="col-auto">
            <button class="btn btn-success" @onclick="MoveL" disabled="@(_busy || !Svc.IsConnected)">MoveL (직선)</button>
            <button class="btn btn-warning" @onclick="UseCurrentPose" disabled="@_busy">현재 포즈 불러오기</button>
            <button class="btn btn-danger" @onclick="EmergencyStop" disabled="@(!Svc.IsConnected)">정지 (StopMotion)</button>
        </div>
    </div>
    <p class="text-muted mt-1" style="max-width:900px"><small>⚠ 입력 포즈는 BASE 좌표계 기준 절대 목표 위치입니다. 공구 번호는 로봇의 현재 활성 공구와 같게 두세요. 다르면 TCP가 바뀌어 엉뚱한 위치로 이동합니다.</small></p>

    <hr />
    <h4>조그</h4>
    <div class="row g-2 align-items-end mb-2" style="max-width:900px">
        <div class="col-auto">
            <label class="form-label d-block">모드</label>
            <div class="btn-group jog-mode-seg" role="group">
                <button type="button" class="btn @(_jogMode == JogMode.Increment ? "btn-primary" : "btn-outline-primary")"
                        @onclick="() => _jogMode = JogMode.Increment">미세 증분</button>
                <button type="button" class="btn @(_jogMode == JogMode.Hold ? "btn-primary" : "btn-outline-primary")"
                        @onclick="() => _jogMode = JogMode.Hold">연속(누름)</button>
            </div>
        </div>
        <div class="col-auto">
            <label class="form-label">좌표계</label>
            <select class="form-select" @bind="_jogFrame" style="width:130px">
                <option value="@JogFrame.Joint">관절</option>
                <option value="@JogFrame.Base">베이스</option>
                <option value="@JogFrame.Tool">툴</option>
                <option value="@JogFrame.Workpiece">작업물</option>
            </select>
        </div>
        <div class="col-auto">
            <label class="form-label">공구(tool)</label>
            <input class="form-control" type="number" min="0" max="15" @bind="_jogTool" style="width:90px" />
        </div>
        @if (_jogFrame == JogFrame.Workpiece)
        {
            <div class="col-auto">
                <label class="form-label">작업물 번호(user)</label>
                <input class="form-control" type="number" min="0" max="14" @bind="_jogUser" style="width:110px" />
            </div>
        }
        <div class="col-auto">
            <label class="form-label">이동량(mm)</label>
            <input class="form-control" type="number" min="0.1" step="0.1" @bind="_jogMaxMm" style="width:130px" />
        </div>
        <div class="col-auto">
            <label class="form-label">회전량(°)</label>
            <input class="form-control" type="number" min="0.1" step="0.1" @bind="_jogMaxDeg" style="width:130px" />
        </div>
        @if (_jogMode == JogMode.Hold)
        {
            <div class="col-auto">
                <label class="form-label">연속 상한(mm)</label>
                <input class="form-control" type="number" min="1" step="1" @bind="_jogHoldMaxMm" style="width:120px"
                       title="누름 연속 조그의 1회 최대 이동 안전 상한(오버런 방지). 이 거리에서 자동 정지." />
            </div>
            <div class="col-auto">
                <label class="form-label">연속 상한(°)</label>
                <input class="form-control" type="number" min="1" step="1" @bind="_jogHoldMaxDeg" style="width:120px"
                       title="누름 연속 조그의 1회 최대 회전 안전 상한(오버런 방지). 이 각도에서 자동 정지." />
            </div>
        }
        <div class="col-auto">
            <label class="form-label">속도(%) : @_jogVel</label>
            <input type="range" class="form-range" min="1" max="100" @bind="_jogVel" style="width:160px" />
        </div>
        <div class="col-auto">
            <label class="form-label">컨트롤러 현재 활성 작업물</label>
            <input class="form-control" type="number" min="0" max="14" @bind="_assumedUser" style="width:110px" />
        </div>
        <div class="col-auto">
            <button class="btn btn-outline-secondary" @onclick="ApplyAssumedUser"
                    disabled="@(!Svc.IsConnected)"
                    title="이 펌웨어는 활성 프레임을 읽을 수 없습니다. 앱 재시작 후 컨트롤러가 0이 아닌 프레임(예: 5)에 있으면 그 번호를 여기 입력하고 눌러 알려주세요. 이후 조그/초기화가 베이스로 변환됩니다.">
                활성 프레임 알려주기
            </button>
        </div>
        <div class="col-auto">
            <button class="btn btn-outline-secondary" @onclick="ResetToBaseFrame"
                    disabled="@(_busy || !Svc.IsConnected)"
                    title="작업물 좌표계 이동 후 활성 프레임이 바뀌어 조그가 역기구학 오류를 내면 누르세요">
                활성 좌표계 초기화(베이스, user=0)
            </button>
        </div>
    </div>
    <p class="text-muted mt-1" style="max-width:900px"><small>⚠ 이 컨트롤러는 활성 작업물 프레임을 <b>읽을 수 없습니다</b>. 앱을 재시작했는데 컨트롤러가 0이 아닌 프레임(예: 작업물 이동 후 5번)에 있으면, 조그/초기화 전에 <b>'컨트롤러 현재 활성 작업물'에 그 번호를 입력하고 '활성 프레임 알려주기'</b>를 먼저 누르세요. 안 그러면 rc=154(관절 지령점 오류)가 납니다.</small></p>
    @if (_jogFrame == JogFrame.Joint)
    {
        <div class="jog-joints">
            @for (int ai = 0; ai < 6; ai++)
            {
                var axis = ai;
                <div class="jog-joint-row">
                    <button class="jog-arrow jog-joint" disabled="@JogDisabled"
                            @onclick="() => JogStep(axis, -1)"
                            @onpointerdown="() => JogHoldStart(axis, -1)" @onpointerup="JogHoldStop"
                            @onpointerleave="JogHoldStop" @onpointercancel="JogHoldStop">J@(axis + 1) −</button>
                    <span class="jog-joint-lb">J@(axis + 1)</span>
                    <button class="jog-arrow jog-joint" disabled="@JogDisabled"
                            @onclick="() => JogStep(axis, +1)"
                            @onpointerdown="() => JogHoldStart(axis, +1)" @onpointerup="JogHoldStop"
                            @onpointerleave="JogHoldStop" @onpointercancel="JogHoldStop">J@(axis + 1) +</button>
                </div>
            }
        </div>
    }
    else
    {
        <div class="jog-panels">
            <div class="jog-panel">
                <div class="jog-panel-hd">TCP Position</div>
                <svg class="jog-svg @(JogDisabled ? "disabled" : "")" viewBox="0 0 200 270">
                    @foreach (var b in PositionArrows)
                    {
                        <g class="jog-shape" @onclick="() => JogStep(b.Axis, b.Sign)"
                           @onpointerdown="() => JogHoldStart(b.Axis, b.Sign)" @onpointerup="JogHoldStop"
                           @onpointerleave="JogHoldStop" @onpointercancel="JogHoldStop">
                            <polygon fill="@b.Color" points="@ArrowPoints(b.Dir, b.Cx, b.Cy, b.Scale)"></polygon>
                            <text class="jog-lb" x="@N(b.Cx)" y="@N(b.Cy)" text-anchor="middle" dominant-baseline="central">@b.Label</text>
                        </g>
                    }
                </svg>
            </div>
            <div class="jog-panel">
                <div class="jog-panel-hd">TCP Orientation</div>
                <svg class="jog-svg @(JogDisabled ? "disabled" : "")" viewBox="0 0 200 270">
                    <g class="jog-shape" @onclick="() => JogStep(5, +1)"
                       @onpointerdown="() => JogHoldStart(5, +1)" @onpointerup="JogHoldStop"
                       @onpointerleave="JogHoldStop" @onpointercancel="JogHoldStop">
                        <path fill="none" stroke="@ClrZ" stroke-width="26" stroke-linecap="round" d="@RzArcLeftD"></path>
                        <polygon fill="@ClrZ" points="@RzHeadLeft"></polygon>
                        <text class="jog-lb" x="46" y="90" text-anchor="middle" dominant-baseline="central">RZ+</text>
                    </g>
                    <g class="jog-shape" @onclick="() => JogStep(5, -1)"
                       @onpointerdown="() => JogHoldStart(5, -1)" @onpointerup="JogHoldStop"
                       @onpointerleave="JogHoldStop" @onpointercancel="JogHoldStop">
                        <path fill="none" stroke="@ClrZ" stroke-width="26" stroke-linecap="round" d="@RzArcRightD"></path>
                        <polygon fill="@ClrZ" points="@RzHeadRight"></polygon>
                        <text class="jog-lb" x="154" y="90" text-anchor="middle" dominant-baseline="central">RZ−</text>
                    </g>
                    @foreach (var b in OrientationArrows)
                    {
                        <g class="jog-shape" @onclick="() => JogStep(b.Axis, b.Sign)"
                           @onpointerdown="() => JogHoldStart(b.Axis, b.Sign)" @onpointerup="JogHoldStop"
                           @onpointerleave="JogHoldStop" @onpointercancel="JogHoldStop">
                            <polygon fill="@b.Color" points="@ArrowPoints(b.Dir, b.Cx, b.Cy, b.Scale)"></polygon>
                            <text class="jog-lb" x="@N(b.Cx)" y="@N(b.Cy)" text-anchor="middle" dominant-baseline="central">@b.Label</text>
                        </g>
                    }
                </svg>
            </div>
        </div>
    }
    <p class="text-muted mt-2" style="max-width:760px"><small>⚠ <b>미세 증분</b>: 클릭 1회 = 입력 이동량(mm)/회전량(°)만큼 정밀 이동(관절=MoveJ 특이점 안전, 직교=MoveL 오프셋·특이점 근처 rc=38 가능). <b>연속(누름)</b>: 누르는 동안 이동, 떼면 정지(StartJOG, 연속 상한까지 후 자동 정지). 저속으로 시작하고, 정지가 안 되면 E-STOP을 누르세요. 공구 번호는 현재 활성 공구와 같게.</small></p>

    <hr />
    <h4>작업물 좌표계 교시 (3점법)</h4>
    <div class="row g-2 align-items-end mb-2" style="max-width:900px">
        <div class="col-auto">
            <label class="form-label">작업물 번호(id)</label>
            <input class="form-control" type="number" min="0" max="14" @bind="_wobjId" style="width:120px" />
        </div>
        <div class="col-auto">
            <label class="form-label">계산법</label>
            <select class="form-select" @bind="_wobjMethod" style="width:210px">
                <option value="0">0: 원점-X축-Z축</option>
                <option value="1">1: 원점-X축-XY평면</option>
            </select>
        </div>
        <div class="col-auto">
            <label class="form-label">측정 방식</label>
            <select class="form-select" @bind="_teachMode" style="width:150px">
                <option value="jog">조그-캡처</option>
                <option value="manual">수동 입력</option>
            </select>
        </div>
    </div>

    @for (int pi = 0; pi < 3; pi++)
    {
        var p = pi;
        <div class="row g-2 align-items-end mb-1" style="max-width:900px">
            <div class="col-auto" style="width:130px"><label class="form-label mb-0">@PointLabels[p]</label></div>
            @if (_teachMode == "jog")
            {
                <div class="col-auto">
                    <button class="btn btn-outline-primary btn-sm" @onclick="@(() => CapturePoint(p + 1))" disabled="@(_busy || !Svc.IsConnected)">현재 위치 캡처</button>
                </div>
                <div class="col-auto">
                    <span class="@(_captured[p] ? "text-success" : "text-muted")">@(_captured[p] ? "캡처됨 " + FormatXyz(_points[p]) : "미캡처")</span>
                </div>
            }
            else
            {
                @for (int k = 0; k < 6; k++)
                {
                    var kk = k;
                    <div class="col-auto">
                        <label class="form-label mb-0">@PoseLabels[kk]</label>
                        <input class="form-control form-control-sm" type="number" step="0.1" @bind="_points[p][kk]" style="width:85px" />
                    </div>
                }
            }
        </div>
    }
    <div class="mt-2">
        <button class="btn btn-primary" @onclick="RegisterWObj" disabled="@(_busy || !Svc.IsConnected)">좌표계 계산 &amp; 등록</button>
        @if (_wobjPose is not null)
        {
            <span class="ms-2 text-success">등록됨 #@_wobjId : @FormatPose6(_wobjPose)</span>
        }
    </div>

    <hr />
    <h4>오프셋 이동 (작업물 좌표계 기준)</h4>
    <div class="row g-2 align-items-end" style="max-width:900px">
        <div class="col-auto">
            <label class="form-label">공구(tool)</label>
            <input class="form-control" type="number" min="0" max="15" @bind="_offTool" style="width:90px" />
        </div>
        <div class="col-auto">
            <label class="form-label">작업물 번호(user)</label>
            <input class="form-control" type="number" min="0" max="14" @bind="_offUser" style="width:110px" />
        </div>
        @for (int i = 0; i < 6; i++)
        {
            var idx = i;
            <div class="col-auto">
                <label class="form-label">@OffsetLabels[idx]</label>
                <input class="form-control" type="number" step="0.1" @bind="_offset[idx]" style="width:85px" />
            </div>
        }
    </div>
    <div class="row g-2 align-items-end mt-1" style="max-width:900px">
        <div class="col-auto">
            <label class="form-label">속도(%) : @_offVel</label>
            <input type="range" class="form-range" min="1" max="100" @bind="_offVel" style="width:180px" />
        </div>
        <div class="col-auto">
            <label class="form-label">기준</label>
            <select class="form-select" @bind="_offMode" style="width:230px">
                <option value="origin">작업물 원점 기준 (절대)</option>
                <option value="current">현재 위치 기준 (증분)</option>
            </select>
            <small class="text-muted d-block">절대 = 입력값이 작업물 좌표계 목표 위치 ([0,0,0]=원점)</small>
        </div>
        <div class="col-auto">
            <button class="btn btn-success" @onclick="MoveByOffset" disabled="@(_busy || !Svc.IsConnected)">오프셋 이동</button>
        </div>
    </div>

@if (!string.IsNullOrEmpty(_message))
{
    <div class="alert @(_isError ? "alert-danger" : "alert-info") mt-3" style="max-width:760px">@_message</div>
}

</div>

@code {
    private static readonly string[] PoseLabels = { "X", "Y", "Z", "Rx", "Ry", "Rz" };
    private static readonly string[] PointLabels = { "점1 (원점)", "점2 (X축 방향)", "점3 (평면/Z)" };
    private static readonly string[] OffsetLabels = { "dX", "dY", "dZ", "dRx", "dRy", "dRz" };

    // RPC 입력
    private int _frameId;
    private readonly double[] _frame = new double[6];
    private readonly double[] _target = new double[6];
    private int _vel = 20;
    private int _moveTool = 1;   // 로봇 현재 활성 공구와 같게 (0으로 두면 TCP가 바뀜)

    // 조그(증분 이동) — 클릭 1회 = 입력한 이동량만큼 정밀 이동 후 정지.
    // 관절 프레임은 MoveJ(관절각 오프셋, IK 없음 → 특이점 rc=38 안전), 직교는 MoveL 오프셋(정밀하나 IK).
    private JogFrame _jogFrame = JogFrame.Base;   // 관절/베이스/툴/작업물
    private int _jogTool = 0;                       // 앵커·이동 공구(현재 활성 공구와 같게)
    private int _jogUser = 0;                       // 작업물 프레임일 때 user 좌표계 번호
    private int _jogVel = 20;
    private double _jogMaxMm = 20;                 // 1회 이동량(병진, mm)
    private double _jogMaxDeg = 15;                // 1회 회전량(회전, °)
    private int _assumedUser;                       // 콜드스타트 시 사용자가 알려주는 컨트롤러 현재 활성 작업물 번호

    private static readonly string[] JointLabels = { "J1", "J2", "J3", "J4", "J5", "J6" };
    // 관절 프레임이면 J1..J6, 직교(베이스/툴/작업물)면 X,Y,Z,Rx,Ry,Rz.
    private string[] JogAxisLabels => _jogFrame == JogFrame.Joint ? JointLabels : PoseLabels;
    // 관절은 전부 회전(°), 직교는 0~2=병진(mm)·3~5=회전(°).
    private bool JogAxisIsRotational(int axis) => _jogFrame == JogFrame.Joint || axis >= 3;
    // 축별 1회 증분량(회전축=회전량°, 병진축=이동량mm).
    private double JogStepDis(int axis) => JogAxisIsRotational(axis) ? _jogMaxDeg : _jogMaxMm;

