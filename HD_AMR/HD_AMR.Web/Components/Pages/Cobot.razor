    private double _jogHoldMaxMm = 100;   // 연속 조그 1회 최대 이동(오버런 안전 상한, mm)
    private double _jogHoldMaxDeg = 90;    // 연속 조그 1회 최대 회전(오버런 안전 상한, °)
    private bool _holding;                 // 누름 연속 조그 진행 중
    private JogFrame _holdFrame;           // 연속 조그 시작 시 프레임(정지에 동일 ref 사용)

    private bool JogDisabled => _busy || !Svc.IsConnected;

