@page "/sequence"
@rendermode InteractiveServer
@using HD_AMR.Communication
@using HD_AMR.Communication.Vision
@using HD_AMR.Service
@using HD_AMR.Service.Sequence
@using HD_AMR.Service.Sequence.Steps
@using HD_AMR.Data.Entities
@inject SequenceService Seq
@inject TeachingService Teaching
@inject CobotService Cobot
@inject CameraService Camera
@inject ParameterService Param
@inject DrawingService DrawingSvc
@inject ILogger<Sequence> Logger
@implements IDisposable

<PageTitle>Sequence</PageTitle>

<h1 class="page-title">Sequence</h1>

<section class="capture-panel">
    <strong>시퀀스 실행</strong>
    @if (!Cobot.IsConnected)
    {
        <div class="hint">⚠ 코봇 RPC 미연결 — 시퀀스 실행 불가.</div>
    }
    @if (Cobot.State is { ErrorCode: not 0 } st)
    {
        <div class="hint"><span class="badge bg-danger">오류 코드 @st.ErrorCode — '오류 해제' 필요</span></div>
    }
    <div class="row g-2 align-items-end mt-1">
        <div class="col-auto">
            <label class="form-label">공구(tool)</label>
            <input class="form-control" type="number" min="0" max="15" style="width:90px"
                   @bind="_context.Tool" disabled="@Seq.IsBusy" />
        </div>
        <div class="col-auto">
            <label class="form-label">속도(%)</label>
            <input class="form-control" type="number" min="1" max="100" style="width:90px"
                   @bind="_context.Velocity" disabled="@Seq.IsBusy" />
        </div>
        <div class="col-auto">
            <button class="btn btn-primary" @onclick="RunAllAsync"
                    disabled="@(!Cobot.IsConnected || Seq.IsBusy)">
                ▶▶ 풀오토
            </button>
        </div>
        <div class="col-auto">
            <button class="btn btn-danger @(Seq.IsBusy ? "btn-lg fw-bold" : "")"
                    @onclick="StopAsync" disabled="@(!Seq.IsBusy)">
                ■ 정지
            </button>
        </div>
        <div class="col-auto">
            <button class="btn btn-outline-warning" @onclick="ResetFaultAsync"
                    disabled="@(Seq.IsBusy || !Cobot.IsConnected)">
                오류 해제 (Reset Error)
            </button>
        </div>
        <div class="col-auto">
            <button class="btn btn-outline-secondary" title="모든 단계 상태·측정값 초기화"
                    @onclick="ResetStatuses" disabled="@Seq.IsBusy">
                ↺ 상태 초기화
            </button>
        </div>
    </div>
    @if (!string.IsNullOrEmpty(_msg))
    {
        <div class="status-message @(_isErr ? "err" : "ok")">@_msg</div>
    }
</section>

<section class="list-section">
    <table class="segment-table">
        <thead>
            <tr>
                <th style="width:3rem">#</th>
                <th>단계</th>
                <th>파라미터 (mm)</th>
                <th>상태</th>
                <th>Operate</th>
            </tr>
        </thead>
        <tbody>
            @{ var idx = 0; }
            @foreach (var step in Seq.Steps)
            {
                idx++;
                var status = Seq.StepStatuses.GetValueOrDefault(step.Key);
                var isCurrent = Seq.CurrentStepKey == step.Key;
                var validation = step.Validate(_context);
                <tr class="@(isCurrent ? "selected" : "")">
                    <td class="step-no">@StepCircle(idx)</td>
                    <td class="step-name">@step.DisplayName</td>
                    <td class="step-params">
                        @if (step.Key == "cobotInspection")
                        {
                            <div class="uv-inputs">
                                <label>방향
                                    <select class="form-select form-select-sm"
                                            @bind="_context.InspectionDirection" @bind:after="SaveOffsetsAsync"
                                            disabled="@Seq.IsBusy">
                                        <option value="@InspectionMoveDirection.Horizontal">수평</option>
                                        <option value="@InspectionMoveDirection.Vertical">수직</option>
                                    </select>
                                </label>
                                <label>U <span class="dir">좌+/우−</span>
                                    <input class="form-control form-control-sm" type="number" step="any"
                                           @bind="_context.InspectionOffsetU" @bind:after="SaveOffsetsAsync"
                                           disabled="@Seq.IsBusy" />
                                </label>
                                <label>V <span class="dir">상+/하−</span>
                                    <input class="form-control form-control-sm" type="number" step="any"
                                           @bind="_context.InspectionOffsetV" @bind:after="SaveOffsetsAsync"
                                           disabled="@Seq.IsBusy" />
                                </label>
                            </div>
                        }
                        else if (step.Key == "cameraAlign")
                        {
                            <div class="uv-inputs">
                                <label>목표거리
                                    <input class="form-control form-control-sm" type="number" step="any"
                                           @bind="_context.CameraTargetDistanceMm" @bind:after="SaveOffsetsAsync"
                                           disabled="@Seq.IsBusy" />
                                </label>
                            </div>
                        }
                        else if (step.Key == "flatSurfaceAlign")
                        {
                            <div class="uv-inputs">
                                <label>레이저중심 Y <span class="dir">카메라→레이저</span>
                                    <input class="form-control form-control-sm" type="number" step="any"
                                           @bind="_context.CameraToLaserShiftYmm" @bind:after="SaveOffsetsAsync"
                                           disabled="@Seq.IsBusy" />
                                </label>
                            </div>
                        }
                        else if (step.Key is "peak1Center" or "peak2Center")
                        {
                            @* 두 행이 같은 값을 편집한다(카메라 장착 방향은 하나뿐). *@
                            <div class="uv-inputs">
                                <label>X부호 <span class="dir">센터링 방향</span>
                                    <select class="form-select form-select-sm"
                                            @bind="_xSign" @bind:after="SaveWeldParamsAsync"
                                            disabled="@Seq.IsBusy">
                                        <option value="1">+1</option>
                                        <option value="-1">−1</option>
                                    </select>
                                </label>
                            </div>
                        }
                        else if (step.Key is "bead1Center" or "bead2Center")
                        {
                            @* 두 행이 같은 값을 편집한다 — 검사캠 장착 오프셋은 하나뿐. *@
                            <div class="uv-inputs">
                                <label>검사캠 X <span class="dir">영상 →오른쪽</span>
                                    <input class="form-control form-control-sm" type="number" step="any"
                                           @bind="_inspectCamOffsetX" @bind:after="SaveWeldParamsAsync"
                                           disabled="@Seq.IsBusy" />
                                </label>
                                <label>검사캠 Y <span class="dir">영상 →아래</span>
                                    <input class="form-control form-control-sm" type="number" step="any"
                                           @bind="_inspectCamOffsetY" @bind:after="SaveWeldParamsAsync"
                                           disabled="@Seq.IsBusy" />
                                </label>
                            </div>
                        }
                        else if (step.Key == "wobjPoint1")
                        {
                            <div class="uv-inputs">
                                <label>작업물 번호 <span class="dir">0~14</span>
                                    <input class="form-control form-control-sm" type="number" min="0" max="14"
                                           @bind="_wobjId" @bind:after="SaveWObjIdAsync"
                                           disabled="@Seq.IsBusy" />
                                </label>
                            </div>
                        }
                        else if (step.Key == "peak2Approach")
                        {
                            <div class="uv-inputs">
                                <label>Pitch
                                    <input class="form-control form-control-sm" type="number" step="any" min="1"
                                           @bind="_pitchMm" @bind:after="SaveWeldParamsAsync"
                                           disabled="@Seq.IsBusy" />
                                </label>
                                <label>방향 <span class="dir">Peak1→2</span>
                                    <select class="form-select form-select-sm"
                                            @bind="_pitchDir" @bind:after="SaveWeldParamsAsync"
                                            disabled="@Seq.IsBusy">
                                        <option value="1">+1</option>
                                        <option value="-1">−1</option>
                                    </select>
                                </label>
                            </div>
                        }
                        else if (step.Key == "inspectionRun")
                        {
                            <div class="uv-inputs">
                                <label>도면
                                    <select class="form-select form-select-sm"
                                            @bind="_context.InspectionDrawingId" @bind:after="OnInspectionDrawingChangedAsync"
                                            disabled="@Seq.IsBusy">
                                        <option value="0">— 선택 —</option>
                                        @foreach (var d in _drawings)
                                        {
                                            <option value="@d.Id">@d.Name</option>
                                        }
                                    </select>
                                </label>
                                <label>티칭설정
                                    <select class="form-select form-select-sm"
                                            @bind="_context.InspectionProfileId" @bind:after="SaveInspectionAsync"
                                            disabled="@(Seq.IsBusy || _inspectionProfiles.Count == 0)">
                                        <option value="0">— 선택 —</option>
                                        @foreach (var p in _inspectionProfiles)
                                        {
                                            <option value="@p.Id">@p.Name</option>
                                        }
                                    </select>
                                </label>
                                <label>Surface ID
                                    <select class="form-select form-select-sm"
                                            @bind="_context.InspectionSurfaceId" @bind:after="SaveInspectionAsync"
                                            disabled="@Seq.IsBusy">
                                        @foreach (var s in SurfaceCatalog.All)
                                        {
                                            <option value="@s.Id">@($"0x{s.Id:X2}") @s.Name</option>
                                        }
                                    </select>
                                </label>
                            </div>
                        }
                    </td>
                    <td class="step-note">
                        @if (status?.State == StepState.Running)
                        {
                            <span class="badge bg-primary">실행 중…</span>
                        }
                        else if (status?.State == StepState.Completed)
                        {
                            <span class="badge bg-success">완료</span>
                            @if (!string.IsNullOrEmpty(status.Message))
                            {
                                <span> @status.Message</span>
                            }
                        }
                        else if (status?.State == StepState.Failed)
                        {
                            <span class="badge bg-danger">실패</span>
                            @if (!string.IsNullOrEmpty(status.Message))
                            {
                                <span> @status.Message</span>
                            }
                        }
                        else if (!validation.IsValid)
                        {
                            <span class="warn">@validation.Message</span>
                        }
                        else
                        {
                            <span>대기</span>
                        }
                    </td>
                    <td class="ops">
                        <button class="btn btn-sm btn-outline-success" title="이 단계만 실행"
                                @onclick="() => RunStepAsync(step.Key)"
                                disabled="@(!Cobot.IsConnected || Seq.IsBusy || !validation.IsValid)">▶ 실행</button>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</section>

@code {
    private readonly SequenceContext _context = new();
    private string? _msg;
    private bool _isErr;
    private readonly CancellationTokenSource _cts = new();

    private const string OffsetUKey = "Sequence.Inspection.OffsetU";
    private const string OffsetVKey = "Sequence.Inspection.OffsetV";
    private const string DirectionKey = "Sequence.Inspection.Direction";
    private const string CameraDistKey = "Sequence.Camera.TargetDistance";
    private const string CameraToLaserShiftKey = "Sequence.FlatSurface.CameraToLaserShiftYmm";

    // ⑱ 검사 수행 — 스텝(InspectionRunStep)이 실행 시 context 값을 사용. 선택값은 DB에 영속.
    private const string InspectionDrawingKey = "Sequence.Inspection.DrawingId";
    private const string InspectionProfileKey = "Sequence.Inspection.ProfileId";
    private const string InspectionSurfaceKey = "Sequence.Inspection.SurfaceId";

    // ⑤~⑫ Peak/Bead 파라미터 — 스텝(WeldSequenceSupport)이 실행 시 같은 키를 DB에서 읽는다.
    private const string XSignKey = "Camera.Axis.XSign";
    private const string PitchMmKey = "Weld.Peak.PitchMm";
    private const string PitchDirKey = "Weld.Peak.PitchDir";

    // 검사캠 장착 오프셋(영상 X/Y, mm) — ⑨/⑬ Bead 센터링이 공유하는 하나의 물리값.
    // 키는 WeldSequenceSupport.InspectCamOffsetX/YKey 와 동일해야 한다(스텝이 실행 시 읽음).
    private const string InspectCamOffsetXKey = "Sequence.InspectCam.OffsetXMm";
    private const string InspectCamOffsetYKey = "Sequence.InspectCam.OffsetYMm";

    private int _xSign = 1;          // 영상 +X → BASE X 부호 (⑥⑩ 센터링)
    private double _pitchMm = 370;   // Peak 간 pitch (mm)
    private int _pitchDir = 1;       // Peak2 이동 방향 (⑧)
    private double _inspectCamOffsetX;  // 검사캠 오프셋 영상 +X(화면 오른쪽) 성분 (mm)
    private double _inspectCamOffsetY;  // 검사캠 오프셋 영상 +Y(화면 아래) 성분 (mm)
    private int _wobjId = 1;         // 작업물 좌표계 번호 (3점법 등록 대상, 0~14)

    // ⑱ 검사 수행 드롭박스 소스.
    private List<Drawing> _drawings = new();
    private List<InspectionProfile> _inspectionProfiles = new();

    protected override async Task OnInitializedAsync()
    {
        Seq.StateChanged += OnSequenceStateChanged;
        await LoadPositionsAsync();
        _context.InspectionOffsetU = await Param.GetDoubleAsync(OffsetUKey) ?? 0;
        _context.InspectionOffsetV = await Param.GetDoubleAsync(OffsetVKey) ?? 0;
        _context.InspectionDirection = (InspectionMoveDirection)(int)(await Param.GetDoubleAsync(DirectionKey) ?? 0);
        _context.CameraTargetDistanceMm = await Param.GetDoubleAsync(CameraDistKey) ?? 400;
        _context.CameraToLaserShiftYmm = await Param.GetDoubleAsync(CameraToLaserShiftKey) ?? -65;
        _xSign = Math.Sign(await Param.GetDoubleAsync(XSignKey) ?? 1) is -1 ? -1 : 1;
        _pitchMm = await Param.GetDoubleAsync(PitchMmKey) ?? 370;
        _pitchDir = Math.Sign(await Param.GetDoubleAsync(PitchDirKey) ?? 1) is -1 ? -1 : 1;
        _inspectCamOffsetX = await Param.GetDoubleAsync(InspectCamOffsetXKey) ?? 0;
        _inspectCamOffsetY = await Param.GetDoubleAsync(InspectCamOffsetYKey) ?? 0;
        _wobjId = (int)(await Param.GetDoubleAsync(WObjPointStep.WObjIdKey) ?? 1);

        // ⑱ 검사 수행: 도면 목록 + 저장된 선택값 복원.
        _drawings = await DrawingSvc.ListAsync();
        _context.InspectionDrawingId = (int)(await Param.GetDoubleAsync(InspectionDrawingKey) ?? 0);
        _context.InspectionProfileId = (int)(await Param.GetDoubleAsync(InspectionProfileKey) ?? 0);
        _context.InspectionSurfaceId = (int)(await Param.GetDoubleAsync(InspectionSurfaceKey) ?? 0x01);
        await LoadInspectionProfilesAsync();

        _ = RefreshLoopAsync();
    }

    /// <summary>선택된 도면의 티칭설정(InspectionProfile) 목록을 로드. 도면 미선택이면 비운다.</summary>
    private async Task LoadInspectionProfilesAsync()
    {
        _inspectionProfiles = _context.InspectionDrawingId > 0
            ? await DrawingSvc.ListProfilesAsync(_context.InspectionDrawingId)
            : new();
        // 현재 선택된 티칭설정이 목록에 없으면(도면 변경 등) 선택 해제.
        if (_inspectionProfiles.All(p => p.Id != _context.InspectionProfileId))
            _context.InspectionProfileId = 0;
    }

    /// <summary>도면 드롭박스 변경 시: 티칭설정 목록 갱신 + 선택값 저장.</summary>
    private async Task OnInspectionDrawingChangedAsync()
    {
        await LoadInspectionProfilesAsync();
        await SaveInspectionAsync();
    }

    private async Task SaveInspectionAsync()
    {
        await Param.SetDoubleAsync(InspectionDrawingKey, _context.InspectionDrawingId, "⑱ 검사 수행: 대상 도면 id");
        await Param.SetDoubleAsync(InspectionProfileKey, _context.InspectionProfileId, "⑱ 검사 수행: 티칭설정(InspectionProfile) id");
        await Param.SetDoubleAsync(InspectionSurfaceKey, _context.InspectionSurfaceId, "⑱ 검사 수행: 비전 CAPTURE_REQ Surface ID");
    }

    private async Task LoadPositionsAsync()
    {
        var list = await Teaching.ListAsync();
        _context.Positions = list.ToDictionary(p => p.Key, p => p);
    }

    private async Task SaveOffsetsAsync()
    {
        await Param.SetDoubleAsync(OffsetUKey, _context.InspectionOffsetU, "검사위치 이동 수평 오프셋 u (mm), 좌+/우− → TOOL Y");
        await Param.SetDoubleAsync(OffsetVKey, _context.InspectionOffsetV, "검사위치 이동 수직 오프셋 v (mm), 상+/하− → TOOL X");
        await Param.SetDoubleAsync(DirectionKey, (int)_context.InspectionDirection, "검사위치 이동 방향 (0=수평, 1=수직/RZ-90°)");
        await Param.SetDoubleAsync(CameraDistKey, _context.CameraTargetDistanceMm, "③ 카메라 거리 정렬 목표 거리 (mm)");
        await Param.SetDoubleAsync(CameraToLaserShiftKey, _context.CameraToLaserShiftYmm, "④ 평탄면 센터링: 카메라→레이저 중심 보정 횡이동 (mm, 툴 Y). 레이저 장착 오프셋");
    }

    private async Task SaveWObjIdAsync()
        => await Param.SetDoubleAsync(WObjPointStep.WObjIdKey, _wobjId,
            "작업물 좌표계 번호 (3점법 등록 대상, 0~14)");

    private async Task SaveWeldParamsAsync()
    {
        await Param.SetDoubleAsync(XSignKey, _xSign, "영상 +X → BASE X 부호 (⑥⑩ Peak 센터링 방향, +1/−1)");
        await Param.SetDoubleAsync(PitchMmKey, _pitchMm, "Peak 간 pitch (mm) — ⑧ 이동량, ⑫ 각도식 분모");
        await Param.SetDoubleAsync(PitchDirKey, _pitchDir, "⑧ Peak2 이동 방향 (+1/−1)");
        await Param.SetDoubleAsync(InspectCamOffsetXKey, _inspectCamOffsetX, "⑨/⑬ 검사캠 장착 오프셋 영상 +X(화면 오른쪽) 성분 (mm)");
        await Param.SetDoubleAsync(InspectCamOffsetYKey, _inspectCamOffsetY, "⑨/⑬ 검사캠 장착 오프셋 영상 +Y(화면 아래) 성분 (mm)");
    }

    private async void OnSequenceStateChanged()
    {
        try { await InvokeAsync(StateHasChanged); }
        catch (ObjectDisposedException) { }
    }

    /// <summary>연결상태·fault 배지를 1초 주기로 갱신.</summary>
    private async Task RefreshLoopAsync()
    {
        using var timer = new PeriodicTimer(TimeSpan.FromSeconds(1));
        try { while (await timer.WaitForNextTickAsync(_cts.Token)) await InvokeAsync(StateHasChanged); }
        catch (OperationCanceledException) { }
    }

    // ── 풀오토 ───────────────────────────────────────────────────────
    private async Task RunAllAsync()
    {
        _msg = null;
        var success = await Seq.RunAllAsync(_context, _cts.Token);
        _isErr = !success;
        _msg = success ? "풀오토 시퀀스 완료." : "시퀀스 중단 — 위 상태를 확인하세요.";
    }

    // ── 세미오토 (단일 단계) ─────────────────────────────────────────
    private async Task RunStepAsync(string stepKey)
    {
        _msg = null;
        var result = await Seq.RunStepAsync(stepKey, _context, _cts.Token);
        _isErr = !result.Success;
        _msg = result.Message;
    }

    // ── 정지 ─────────────────────────────────────────────────────────
    private async Task StopAsync() => await Seq.StopAsync();

    // ── 상태 초기화 ──────────────────────────────────────────────────
    private void ResetStatuses()
    {
        Seq.Reset();
        _context.Bag.Clear();   // 측정값·앵커·플래그도 초기화 — 새 사이클 시작
        _isErr = false;
        _msg = "시퀀스 상태 초기화 완료.";
    }

    // ── 오류 해제 ────────────────────────────────────────────────────
    private async Task ResetFaultAsync()
    {
        _msg = null;
        try
        {
            var rc = await Cobot.ResetErrorAsync();
            _isErr = rc != 0;
            _msg = rc == 0 ? "오류 해제 완료." : $"오류 해제 실패 (rc={rc}).";
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Sequence reset error failed");
            _isErr = true;
            _msg = $"오류 해제 실패: {ex.Message}";
        }
    }

    /// <summary>원형 숫자 표기 — 유니코드 블록 3개로 1~50 커버 (①~⑳, ㉑~㉟, ㊱~㊿).</summary>
    private static string StepCircle(int n) => n switch
    {
        >= 1 and <= 20 => char.ConvertFromUtf32(0x2460 + n - 1),    // ①~⑳
        >= 21 and <= 35 => char.ConvertFromUtf32(0x3251 + n - 21),  // ㉑~㉟
        >= 36 and <= 50 => char.ConvertFromUtf32(0x32B1 + n - 36),  // ㊱~㊿
        _ => $"({n})"
    };

    public void Dispose()
    {
        Seq.StateChanged -= OnSequenceStateChanged;
        _cts.Cancel();
        _cts.Dispose();
    }
}
