@page "/sequence"
@rendermode InteractiveServer
@using HD_AMR.Communication
@using HD_AMR.Service
@using HD_AMR.Service.Sequence
@inject SequenceService Seq
@inject TeachingService Teaching
@inject CobotService Cobot
@inject CameraService Camera
@inject ParameterService Param
@inject ILogger<Sequence> Logger
@implements IDisposable

<PageTitle>Sequence</PageTitle>

<h1 class="page-title">Sequence</h1>

<section class="capture-panel">
    <strong>시퀀스 실행</strong>
    @if (!Cobot.IsConnected)
    {
        <div class="hint">⚠ 코봇 RPC 미연결 — 시퀀스 실행 불가.</div>
    }
    @if (Cobot.State is { ErrorCode: not 0 } st)
    {
        <div class="hint"><span class="badge bg-danger">오류 코드 @st.ErrorCode — '오류 해제' 필요</span></div>
    }
    <div class="row g-2 align-items-end mt-1">
        <div class="col-auto">
            <label class="form-label">공구(tool)</label>
            <input class="form-control" type="number" min="0" max="15" style="width:90px"
                   @bind="_context.Tool" disabled="@Seq.IsBusy" />
        </div>
        <div class="col-auto">
            <label class="form-label">속도(%)</label>
            <input class="form-control" type="number" min="1" max="100" style="width:90px"
                   @bind="_context.Velocity" disabled="@Seq.IsBusy" />
        </div>
        <div class="col-auto">
            <button class="btn btn-primary" @onclick="RunAllAsync"
                    disabled="@(!Cobot.IsConnected || Seq.IsBusy)">
                ▶▶ 풀오토
            </button>
        </div>
        <div class="col-auto">
            <button class="btn btn-danger @(Seq.IsBusy ? "btn-lg fw-bold" : "")"
                    @onclick="StopAsync" disabled="@(!Seq.IsBusy)">
                ■ 정지
            </button>
        </div>
        <div class="col-auto">
            <button class="btn btn-outline-warning" @onclick="ResetFaultAsync"
                    disabled="@(Seq.IsBusy || !Cobot.IsConnected)">
                오류 해제 (Reset Error)
            </button>
        </div>
    </div>
    @if (!string.IsNullOrEmpty(_msg))
    {
        <div class="status-message @(_isErr ? "err" : "ok")">@_msg</div>
    }
</section>

<section class="list-section">
    <table class="segment-table">
        <thead>
            <tr>
                <th style="width:3rem">#</th>
                <th>단계</th>
                <th>이동 오프셋 (mm)</th>
                <th>상태</th>
                <th>Operate</th>
            </tr>
        </thead>
        <tbody>
            @{ var idx = 0; }
            @foreach (var step in Seq.Steps)
            {
                idx++;
                var status = Seq.StepStatuses.GetValueOrDefault(step.Key);
                var isCurrent = Seq.CurrentStepKey == step.Key;
                var validation = step.Validate(_context);
                <tr class="@(isCurrent ? "selected" : "")">
                    <td class="step-no">@StepCircle(idx)</td>
                    <td class="step-name">@step.DisplayName</td>
                    <td class="step-params">
                        @if (step.Key == "cobotInspection")
                        {
                            <div class="uv-inputs">
                                <label>U <span class="dir">좌+/우−</span>
                                    <input class="form-control form-control-sm" type="number" step="any"
                                           @bind="_context.InspectionOffsetU" @bind:after="SaveOffsetsAsync"
                                           disabled="@Seq.IsBusy" />
                                </label>
                                <label>V <span class="dir">상+/하−</span>
                                    <input class="form-control form-control-sm" type="number" step="any"
                                           @bind="_context.InspectionOffsetV" @bind:after="SaveOffsetsAsync"
                                           disabled="@Seq.IsBusy" />
                                </label>
                            </div>
                        }
                    </td>
                    <td class="step-note">
                        @if (status?.State == StepState.Running)
                        {
                            <span class="badge bg-primary">실행 중…</span>
                        }
                        else if (status?.State == StepState.Completed)
                        {
                            <span class="badge bg-success">완료</span>
                            @if (!string.IsNullOrEmpty(status.Message))
                            {
                                <span> @status.Message</span>
                            }
                        }
                        else if (status?.State == StepState.Failed)
                        {
                            <span class="badge bg-danger">실패</span>
                            @if (!string.IsNullOrEmpty(status.Message))
                            {
                                <span> @status.Message</span>
                            }
                        }
                        else if (!validation.IsValid)
                        {
                            <span class="warn">@validation.Message</span>
                        }
                        else
                        {
                            <span>대기</span>
                        }
                    </td>
                    <td class="ops">
                        <button class="btn btn-sm btn-outline-success" title="이 단계만 실행"
                                @onclick="() => RunStepAsync(step.Key)"
                                disabled="@(!Cobot.IsConnected || Seq.IsBusy || !validation.IsValid)">▶ 실행</button>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</section>

@code {
    private readonly SequenceContext _context = new();
    private string? _msg;
    private bool _isErr;
    private readonly CancellationTokenSource _cts = new();

    private const string OffsetUKey = "Sequence.Inspection.OffsetU";
    private const string OffsetVKey = "Sequence.Inspection.OffsetV";

    protected override async Task OnInitializedAsync()
    {
        Seq.StateChanged += OnSequenceStateChanged;
        await LoadPositionsAsync();
        _context.InspectionOffsetU = await Param.GetDoubleAsync(OffsetUKey) ?? 0;
        _context.InspectionOffsetV = await Param.GetDoubleAsync(OffsetVKey) ?? 0;
        _ = RefreshLoopAsync();
    }

    private async Task LoadPositionsAsync()
    {
        var list = await Teaching.ListAsync();
        _context.Positions = list.ToDictionary(p => p.Key, p => p);
    }

    private async Task SaveOffsetsAsync()
    {
        await Param.SetDoubleAsync(OffsetUKey, _context.InspectionOffsetU, "검사위치 이동 수평 오프셋 u (mm), 좌+/우− → TOOL Y");
        await Param.SetDoubleAsync(OffsetVKey, _context.InspectionOffsetV, "검사위치 이동 수직 오프셋 v (mm), 상+/하− → TOOL X");
    }

    private async void OnSequenceStateChanged()
    {
        try { await InvokeAsync(StateHasChanged); }
        catch (ObjectDisposedException) { }
    }

    /// <summary>연결상태·fault 배지를 1초 주기로 갱신.</summary>
    private async Task RefreshLoopAsync()
    {
        using var timer = new PeriodicTimer(TimeSpan.FromSeconds(1));
        try { while (await timer.WaitForNextTickAsync(_cts.Token)) await InvokeAsync(StateHasChanged); }
        catch (OperationCanceledException) { }
    }

    // ── 풀오토 ───────────────────────────────────────────────────────
    private async Task RunAllAsync()
    {
        _msg = null;
        var success = await Seq.RunAllAsync(_context, _cts.Token);
        _isErr = !success;
        _msg = success ? "풀오토 시퀀스 완료." : "시퀀스 중단 — 위 상태를 확인하세요.";
    }

    // ── 세미오토 (단일 단계) ─────────────────────────────────────────
    private async Task RunStepAsync(string stepKey)
    {
        _msg = null;
        var result = await Seq.RunStepAsync(stepKey, _context, _cts.Token);
        _isErr = !result.Success;
        _msg = result.Message;
    }

    // ── 정지 ─────────────────────────────────────────────────────────
    private async Task StopAsync() => await Seq.StopAsync();

    // ── 오류 해제 ────────────────────────────────────────────────────
    private async Task ResetFaultAsync()
    {
        _msg = null;
        try
        {
            var rc = await Cobot.ResetErrorAsync();
            _isErr = rc != 0;
            _msg = rc == 0 ? "오류 해제 완료." : $"오류 해제 실패 (rc={rc}).";
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Sequence reset error failed");
            _isErr = true;
            _msg = $"오류 해제 실패: {ex.Message}";
        }
    }

    private static string StepCircle(int n) => n switch
    {
        1 => "①", 2 => "②", 3 => "③", 4 => "④", 5 => "⑤",
        6 => "⑥", 7 => "⑦", 8 => "⑧", 9 => "⑨", 10 => "⑩",
        _ => $"({n})"
    };

    public void Dispose()
    {
        Seq.StateChanged -= OnSequenceStateChanged;
        _cts.Cancel();
        _cts.Dispose();
    }
}
