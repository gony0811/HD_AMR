@using HD_AMR.Service
@using HD_AMR.Enums
@inject AMRService Amr
@inject CobotService Cobot
@inject VisionInterfaceService Vision
@implements IDisposable

<div class="tb-root px-4">
    <div class="tb-left">
        <div class="tb-group">
            <span class="tb-icon tb-icon-robot" aria-hidden="true"></span>
            <span class="tb-label">AMR</span>
            <span class="tb-badge @(Amr.IsConnected ? "tb-badge-on" : "tb-badge-off")">@(Amr.IsConnected ? "연결" : "미연결")</span>
        </div>

        <div class="tb-group">
            <span class="tb-icon tb-icon-gear" aria-hidden="true"></span>
            <span class="tb-label">Cobot</span>
            <span class="tb-badge @(Cobot.IsConnected ? "tb-badge-on" : "tb-badge-off")">@(Cobot.IsConnected ? "연결" : "미연결")</span>
        </div>

        <div class="tb-group">
            <span class="tb-icon tb-icon-vision" aria-hidden="true"></span>
            <span class="tb-label">Vision</span>
            <span class="tb-badge @(Vision.Client.IsConnected ? "tb-badge-on" : "tb-badge-off")">@(Vision.Client.IsConnected ? "연결" : "미연결")</span>
        </div>

        <div class="tb-group tb-lamp">
            <span class="tb-icon tb-icon-lightbulb" aria-hidden="true"></span>
            <span class="tb-lamp-dot @(LampRed ? "is-red-on" : "")"></span>
            <span class="tb-lamp-dot @(LampYellow ? "is-yellow-on" : "")"></span>
            <span class="tb-lamp-dot @(LampGreen ? "is-green-on" : "")"></span>
        </div>

        <div class="tb-group tb-battery">
            <BatteryIndicator Percent="BatteryPercent" Charging="IsCharging" HeightRem="1.35" />
            <span class="tb-battery-text">@(BatteryPercent?.ToString() ?? "--")%</span>
        </div>
    </div>

    <div class="tb-right">
        <a href="https://www.naver.com" target="_blank">About</a>
    </div>
</div>

@code {
    [Parameter] public bool LampRed { get; set; }
    [Parameter] public bool LampYellow { get; set; }
    [Parameter] public bool LampGreen { get; set; }

    private int? BatteryPercent => Amr.LatestStatus is { } s ? (int)Math.Round(s.Battery.LevelPercent) : null;
    private bool IsCharging => Amr.LatestStatus?.Battery.ChargingState == ChargingState.Charging;

    private CancellationTokenSource? _cts;

    protected override void OnInitialized()
    {
        _cts = new CancellationTokenSource();
        _ = PollLoop(_cts.Token);
    }

    private async Task PollLoop(CancellationToken ct)
    {
        try
        {
            using var timer = new PeriodicTimer(TimeSpan.FromSeconds(1));
            while (await timer.WaitForNextTickAsync(ct))
                await InvokeAsync(StateHasChanged);
        }
        catch (OperationCanceledException) { }
    }

    public void Dispose()
    {
        _cts?.Cancel();
        _cts?.Dispose();
    }
}
