@using HD_AMR.Service
@inject CobotService Cobot
@implements IDisposable

<div class="tb-root px-4">
    <div class="tb-left">
        <div class="tb-group">
            <span class="tb-icon tb-icon-robot" aria-hidden="true"></span>
            <span class="tb-label">AMR</span>
            <span class="tb-badge tb-badge-off">@AmrStatus</span>
            <span class="tb-badge tb-badge-value">@AmrValue</span>
        </div>

        <div class="tb-group">
            <span class="tb-icon tb-icon-gear" aria-hidden="true"></span>
            <span class="tb-label">Cobot</span>
            <span class="tb-badge @(Cobot.IsConnected ? "tb-badge-on" : "tb-badge-off")">@(Cobot.IsConnected ? "연결" : "미연결")</span>
        </div>

        <div class="tb-group tb-lamp">
            <span class="tb-icon tb-icon-lightbulb" aria-hidden="true"></span>
            <span class="tb-lamp-dot @(LampRed ? "is-red-on" : "")"></span>
            <span class="tb-lamp-dot @(LampYellow ? "is-yellow-on" : "")"></span>
            <span class="tb-lamp-dot @(LampGreen ? "is-green-on" : "")"></span>
        </div>

        <div class="tb-group tb-battery">
            <span class="tb-icon tb-icon-battery" aria-hidden="true"></span>
            <span class="tb-battery-text">@(BatteryPercent?.ToString() ?? "--")%</span>
        </div>
    </div>

    <div class="tb-right">
        <a href="https://learn.microsoft.com/aspnet/core/" target="_blank">About</a>
    </div>
</div>

@code {
    [Parameter] public string AmrStatus { get; set; } = "OFF";
    [Parameter] public string AmrValue { get; set; } = "--";
    [Parameter] public bool LampRed { get; set; }
    [Parameter] public bool LampYellow { get; set; }
    [Parameter] public bool LampGreen { get; set; }
    [Parameter] public int? BatteryPercent { get; set; }

    private CancellationTokenSource? _cts;

    protected override void OnInitialized()
    {
        _cts = new CancellationTokenSource();
        _ = PollLoop(_cts.Token);
    }

    private async Task PollLoop(CancellationToken ct)
    {
        try
        {
            using var timer = new PeriodicTimer(TimeSpan.FromSeconds(1));
            while (await timer.WaitForNextTickAsync(ct))
                await InvokeAsync(StateHasChanged);
        }
        catch (OperationCanceledException) { }
    }

    public void Dispose()
    {
        _cts?.Cancel();
        _cts?.Dispose();
    }
}
