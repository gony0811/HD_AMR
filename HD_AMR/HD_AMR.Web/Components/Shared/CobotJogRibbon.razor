@using HD_AMR.Communication
@using HD_AMR.Service
@inject CobotService Svc
@implements IDisposable

@* 자립형 조그 리본 컴포넌트. CobotService 하나에만 의존하며 자체 busy/opCts 게이트·폴링·정리를 가진다.
   ShowSafetyHeader=true(기본)면 연결 상태 + 서보/E-STOP/오류해제 컴팩트 바를 함께 렌더해 팝업만으로도
   안전하게 정지할 수 있다(코봇 페이지처럼 이미 E-STOP 바가 있으면 false 로 끈다). *@

@if (ShowSafetyHeader)
{
    <div class="estop-bar">
        <span class="badge @(Svc.IsConnected ? "bg-success" : "bg-secondary")">명령 @(Svc.IsConnected ? "연결됨" : "끊김")</span>
        <span class="badge @(Svc.IsStateConnected ? "bg-success" : "bg-secondary")">상태 @(Svc.IsStateConnected ? "수신중" : "끊김")</span>
        @if (Svc.State is { } fs)
        {
            <span class="badge bg-info" title="상태 패킷(20004)에서 읽은 컨트롤러 현재 활성 좌표계">
                활성 툴 #@fs.Tool / 작업물 #@fs.User
            </span>
        }
        @if (Svc.State is { ErrorCode: not 0 } st)
        {
            <span class="badge bg-danger">오류 코드 @st.ErrorCode — '오류 해제' 필요</span>
        }
        <button class="btn @(Svc.IsServoEnabled ? "btn-success" : "btn-outline-secondary")"
                @onclick="ToggleServo" disabled="@(!Svc.IsConnected)">
            @(Svc.IsServoEnabled ? "서보 ON" : "서보 OFF")
        </button>
        <button class="btn btn-danger estop-btn" @onclick="EmergencyStop" disabled="@(!Svc.IsConnected)">
            ■ 긴급 정지 (E-STOP)
        </button>
        <button class="btn btn-outline-warning" @onclick="ResetError" disabled="@(_busy || !Svc.IsConnected)">
            오류 해제 (Reset Error)
        </button>
    </div>
}

<div class="row g-2 align-items-end mb-2" style="max-width:900px">
    <div class="col-auto">
        <label class="form-label d-block">모드</label>
        <div class="btn-group jog-mode-seg" role="group">
            <button type="button" class="btn @(_jogMode == JogMode.Increment ? "btn-primary" : "btn-outline-primary")"
                    @onclick="() => _jogMode = JogMode.Increment">미세 증분</button>
            <button type="button" class="btn @(_jogMode == JogMode.Hold ? "btn-primary" : "btn-outline-primary")"
                    @onclick="() => _jogMode = JogMode.Hold">연속(누름)</button>
        </div>
    </div>
    <div class="col-auto">
        <label class="form-label">좌표계</label>
        <select class="form-select" @bind="_jogFrame" style="width:130px">
            <option value="@JogFrame.Joint">관절</option>
            <option value="@JogFrame.Base">베이스</option>
            <option value="@JogFrame.Tool">툴</option>
            <option value="@JogFrame.Workpiece">작업물</option>
        </select>
    </div>
    <div class="col-auto">
        <label class="form-label">공구(tool)</label>
        <input class="form-control" type="number" min="0" max="15" @bind="_jogTool" style="width:90px" />
    </div>
    @if (_jogFrame == JogFrame.Workpiece)
    {
        <div class="col-auto">
            <label class="form-label">작업물 번호(user)</label>
            <input class="form-control" type="number" min="0" max="14" @bind="_jogUser" style="width:110px" />
        </div>
    }
    <div class="col-auto">
        <label class="form-label">이동량(mm)</label>
        <input class="form-control" type="number" min="0.1" step="0.1" @bind="_jogMaxMm" style="width:130px" />
    </div>
    <div class="col-auto">
        <label class="form-label">회전량(°)</label>
        <input class="form-control" type="number" min="0.1" step="0.1" @bind="_jogMaxDeg" style="width:130px" />
    </div>
    @if (_jogMode == JogMode.Hold)
    {
        <div class="col-auto">
            <label class="form-label">연속 상한(mm)</label>
            <input class="form-control" type="number" min="1" step="1" @bind="_jogHoldMaxMm" style="width:120px"
                   title="누름 연속 조그의 1회 최대 이동 안전 상한(오버런 방지). 이 거리에서 자동 정지." />
        </div>
        <div class="col-auto">
            <label class="form-label">연속 상한(°)</label>
            <input class="form-control" type="number" min="1" step="1" @bind="_jogHoldMaxDeg" style="width:120px"
                   title="누름 연속 조그의 1회 최대 회전 안전 상한(오버런 방지). 이 각도에서 자동 정지." />
        </div>
    }
    <div class="col-auto">
        <label class="form-label">속도(%) : @_jogVel</label>
        <input type="range" class="form-range" min="1" max="100" @bind="_jogVel" style="width:160px" />
    </div>
    <div class="col-auto">
        <label class="form-label">컨트롤러 현재 활성 작업물</label>
        <input class="form-control" type="number" min="0" max="14" @bind="_assumedUser" style="width:110px" />
    </div>
    <div class="col-auto">
        <button class="btn btn-outline-secondary" @onclick="ApplyAssumedUser"
                disabled="@(!Svc.IsConnected)"
                title="이 펌웨어는 활성 프레임을 읽을 수 없습니다. 앱 재시작 후 컨트롤러가 0이 아닌 프레임(예: 5)에 있으면 그 번호를 여기 입력하고 눌러 알려주세요. 이후 조그/초기화가 베이스로 변환됩니다.">
            활성 프레임 알려주기
        </button>
    </div>
    <div class="col-auto">
        <button class="btn btn-outline-secondary" @onclick="ResetToBaseFrame"
                disabled="@(_busy || !Svc.IsConnected)"
                title="작업물 좌표계 이동 후 활성 프레임이 바뀌어 조그가 역기구학 오류를 내면 누르세요">
            활성 좌표계 초기화(베이스, user=0)
        </button>
    </div>
</div>
<p class="text-muted mt-1" style="max-width:900px"><small>⚠ 이 컨트롤러는 활성 작업물 프레임을 <b>읽을 수 없습니다</b>. 앱을 재시작했는데 컨트롤러가 0이 아닌 프레임(예: 작업물 이동 후 5번)에 있으면, 조그/초기화 전에 <b>'컨트롤러 현재 활성 작업물'에 그 번호를 입력하고 '활성 프레임 알려주기'</b>를 먼저 누르세요. 안 그러면 rc=154(관절 지령점 오류)가 납니다.</small></p>
@if (_jogFrame == JogFrame.Joint)
{
    <div class="jog-joints">
        @for (int ai = 0; ai < 6; ai++)
        {
            var axis = ai;
            <div class="jog-joint-row">
                <button class="jog-arrow jog-joint" disabled="@JogDisabled"
                        @onclick="() => JogStep(axis, -1)"
                        @onpointerdown="() => JogHoldStart(axis, -1)" @onpointerup="JogHoldStop"
                        @onpointerleave="JogHoldStop" @onpointercancel="JogHoldStop">J@(axis + 1) −</button>
                <span class="jog-joint-lb">J@(axis + 1)</span>
                <button class="jog-arrow jog-joint" disabled="@JogDisabled"
                        @onclick="() => JogStep(axis, +1)"
                        @onpointerdown="() => JogHoldStart(axis, +1)" @onpointerup="JogHoldStop"
                        @onpointerleave="JogHoldStop" @onpointercancel="JogHoldStop">J@(axis + 1) +</button>
            </div>
        }
    </div>
}
else
{
    <div class="jog-panels">
        <div class="jog-panel">
            <div class="jog-panel-hd">TCP Position</div>
            <svg class="jog-svg @(JogDisabled ? "disabled" : "")" viewBox="0 0 200 270">
                @foreach (var b in PositionArrows)
                {
                    <g class="jog-shape" @onclick="() => JogStep(b.Axis, b.Sign)"
                       @onpointerdown="() => JogHoldStart(b.Axis, b.Sign)" @onpointerup="JogHoldStop"
                       @onpointerleave="JogHoldStop" @onpointercancel="JogHoldStop">
                        <polygon fill="@b.Color" points="@ArrowPoints(b.Dir, b.Cx, b.Cy, b.Scale)"></polygon>
                        <text class="jog-lb" x="@N(b.Cx)" y="@N(b.Cy)" text-anchor="middle" dominant-baseline="central">@b.Label</text>
                    </g>
                }
            </svg>
        </div>
        <div class="jog-panel">
            <div class="jog-panel-hd">TCP Orientation</div>
            <svg class="jog-svg @(JogDisabled ? "disabled" : "")" viewBox="0 0 200 270">
                <g class="jog-shape" @onclick="() => JogStep(5, +1)"
                   @onpointerdown="() => JogHoldStart(5, +1)" @onpointerup="JogHoldStop"
                   @onpointerleave="JogHoldStop" @onpointercancel="JogHoldStop">
                    <path fill="none" stroke="@ClrZ" stroke-width="20" stroke-linecap="square" d="@RzArcLeftD"></path>
                    <polygon fill="@ClrZ" points="@RzHeadLeft"></polygon>
                    <text class="jog-lb" x="46" y="90" text-anchor="middle" dominant-baseline="central">RZ+</text>
                </g>
                <g class="jog-shape" @onclick="() => JogStep(5, -1)"
                   @onpointerdown="() => JogHoldStart(5, -1)" @onpointerup="JogHoldStop"
                   @onpointerleave="JogHoldStop" @onpointercancel="JogHoldStop">
                    <path fill="none" stroke="@ClrZ" stroke-width="20" stroke-linecap="square" d="@RzArcRightD"></path>
                    <polygon fill="@ClrZ" points="@RzHeadRight"></polygon>
                    <text class="jog-lb" x="154" y="90" text-anchor="middle" dominant-baseline="central">RZ−</text>
                </g>
                @foreach (var b in OrientationArrows)
                {
                    <g class="jog-shape" @onclick="() => JogStep(b.Axis, b.Sign)"
                       @onpointerdown="() => JogHoldStart(b.Axis, b.Sign)" @onpointerup="JogHoldStop"
                       @onpointerleave="JogHoldStop" @onpointercancel="JogHoldStop">
                        <polygon fill="@b.Color" points="@ArrowPoints(b.Dir, b.Cx, b.Cy, b.Scale)"></polygon>
                        <text class="jog-lb" x="@N(b.Cx)" y="@N(b.Cy)" text-anchor="middle" dominant-baseline="central">@b.Label</text>
                    </g>
                }
            </svg>
        </div>
    </div>
}
<p class="text-muted mt-2" style="max-width:760px"><small>⚠ <b>미세 증분</b>: 클릭 1회 = 입력 이동량(mm)/회전량(°)만큼 정밀 이동(관절=MoveJ 특이점 안전, 직교=MoveL 오프셋·특이점 근처 rc=38 가능). <b>연속(누름)</b>: 누르는 동안 이동, 떼면 정지(StartJOG, 연속 상한까지 후 자동 정지). 저속으로 시작하고, 정지가 안 되면 E-STOP을 누르세요. 공구 번호는 현재 활성 공구와 같게.</small></p>

@if (_message is { } msg)
{
    <div class="alert @(_isError ? "alert-danger" : "alert-info") py-2 mt-2 mb-0">@msg</div>
}

@code {
    /// <summary>연결 상태 + 서보/E-STOP/오류해제 컴팩트 바를 리본 위에 렌더할지. 코봇 페이지처럼 페이지가
    /// 이미 E-STOP 바를 가진 경우 false 로 끈다(기본 true — 팝업 단독 사용 시 안전 정지 경로 제공).</summary>
    [Parameter] public bool ShowSafetyHeader { get; set; } = true;

    private static readonly string[] PoseLabels = { "X", "Y", "Z", "Rx", "Ry", "Rz" };

    // 조그(증분 이동) — 클릭 1회 = 입력한 이동량만큼 정밀 이동 후 정지.
    // 관절 프레임은 MoveJ(관절각 오프셋, IK 없음 → 특이점 rc=38 안전), 직교는 MoveL 오프셋(정밀하나 IK).
    private JogFrame _jogFrame = JogFrame.Base;   // 관절/베이스/툴/작업물
    private int _jogTool = 0;                       // 앵커·이동 공구(현재 활성 공구와 같게)
    private int _jogUser = 0;                       // 작업물 프레임일 때 user 좌표계 번호
    private int _jogVel = 20;
    private double _jogMaxMm = 20;                 // 1회 이동량(병진, mm)
    private double _jogMaxDeg = 15;                // 1회 회전량(회전, °)
    private int _assumedUser;                       // 콜드스타트 시 사용자가 알려주는 컨트롤러 현재 활성 작업물 번호

    private static readonly string[] JointLabels = { "J1", "J2", "J3", "J4", "J5", "J6" };
    // 관절 프레임이면 J1..J6, 직교(베이스/툴/작업물)면 X,Y,Z,Rx,Ry,Rz.
    private string[] JogAxisLabels => _jogFrame == JogFrame.Joint ? JointLabels : PoseLabels;
    // 관절은 전부 회전(°), 직교는 0~2=병진(mm)·3~5=회전(°).
    private bool JogAxisIsRotational(int axis) => _jogFrame == JogFrame.Joint || axis >= 3;
    // 축별 1회 증분량(회전축=회전량°, 병진축=이동량mm).
    private double JogStepDis(int axis) => JogAxisIsRotational(axis) ? _jogMaxDeg : _jogMaxMm;

    // 조그 모드 & 누름 연속(hold-to-jog)
    private enum JogMode { Increment, Hold }
    private JogMode _jogMode = JogMode.Increment;
    private double _jogHoldMaxMm = 100;   // 연속 조그 1회 최대 이동(오버런 안전 상한, mm)
    private double _jogHoldMaxDeg = 90;    // 연속 조그 1회 최대 회전(오버런 안전 상한, °)
    private bool _holding;                 // 누름 연속 조그 진행 중
    private JogFrame _holdFrame;           // 연속 조그 시작 시 프레임(정지에 동일 ref 사용)

    private bool JogDisabled => _busy || !Svc.IsConnected;

    // 화살표 패드(SVG). 축 0~5 = X,Y,Z,Rx,Ry,Rz. docs/jog_ui.png 배치·색·방향 매칭.
    private const string ClrX = "#F08080";  // X/RX 빨강
    private const string ClrY = "#7EC850";  // Y/RY 초록
    private const string ClrZ = "#5B9BD5";  // Z/RZ 파랑
    private record JogArrow(int Axis, int Sign, string Dir, string Color, string Label, double Cx, double Cy, double Scale);
    private static readonly JogArrow[] PositionArrows =
    {
        new(2, +1, "up",    ClrZ, "Z+", 52, 60, 1.2),
        new(2, -1, "down",  ClrZ, "Z−", 148, 60, 1.2),
        new(0, -1, "up",    ClrX, "X−", 100, 139, 1.0),
        new(0, +1, "down",  ClrX, "X+", 100, 221, 1.0),
        new(1, -1, "left",  ClrY, "Y−", 50, 180, 1.0),
        new(1, +1, "right", ClrY, "Y+", 150, 180, 1.0),
    };
    private static readonly JogArrow[] OrientationArrows =
    {
        new(4, -1, "up",    ClrY, "RY−", 100, 149, 1.0),
        new(4, +1, "down",  ClrY, "RY+", 100, 231, 1.0),
        new(3, +1, "left",  ClrX, "RX+", 50, 190, 1.0),
        new(3, -1, "right", ClrX, "RX−", 150, 190, 1.0),
    };
    // RZ 곡선 아치(파랑) — 상단 무지개, 좌=RZ+, 우=RZ−. 아치 + 화살촉.
    // 화살촉을 키움: 밑변 30→32(뷰포트 폭 안 최대), 길이 34→48로 길게 뾰족하게(아치 끝 y=124에 겹치게 base y=114).
    private const string RzArcLeftD  = "M 100 40 A 84 84 0 0 0 16 124";
    private const string RzArcRightD = "M 100 40 A 84 84 0 0 1 184 124";
    private const string RzHeadLeft  = "0,114 32,114 16,162";
    private const string RzHeadRight = "168,114 200,114 184,162";

    private static string N(double v) => v.ToString("0.#", System.Globalization.CultureInfo.InvariantCulture);

    // '위' 화살표(뚱뚱한 블록: 사각 꼬리 + 넓은 삼각 머리) 7점을 방향별 회전·스케일해 polygon points 생성.
    private static string ArrowPoints(string dir, double cx, double cy, double scale)
    {
        (double x, double y)[] up =
        {
            (0, -32), (28, -4), (12, -4), (12, 32), (-12, 32), (-12, -4), (-28, -4),
        };
        double ang = dir switch { "down" => 180.0, "left" => 270.0, "right" => 90.0, _ => 0.0 };
        double r = ang * Math.PI / 180.0, c = Math.Cos(r), s = Math.Sin(r);
        var sb = new System.Text.StringBuilder();
        foreach (var (x, y) in up)
        {
            double sx = x * scale, sy = y * scale;
            double rx = sx * c - sy * s, ry = sx * s + sy * c;
            sb.Append(N(cx + rx)).Append(',').Append(N(cy + ry)).Append(' ');
        }
        return sb.ToString().TrimEnd();
    }

    private bool _busy;
    private string? _message;
    private bool _isError;

    private CancellationTokenSource? _cts;
    private CancellationTokenSource? _opCts;   // 진행 중인 명령 취소(긴급 정지 시)

    protected override void OnInitialized()
    {
        _cts = new CancellationTokenSource();
        _ = PollLoop(_cts.Token);
    }

    private async Task PollLoop(CancellationToken ct)
    {
        try
        {
            using var timer = new PeriodicTimer(TimeSpan.FromSeconds(1));
            while (await timer.WaitForNextTickAsync(ct))
            {
                await InvokeAsync(StateHasChanged);
            }
        }
        catch (OperationCanceledException) { }
    }

    // 활성 작업물 좌표계를 베이스(0)로 초기화(무변위 MoveJ). 작업물 좌표계 이동 후 조그가
    // 역기구학 오류를 낼 때 사용. 공구는 현재 조그 공구(_jogTool) 기준으로 맞춘다.
    private async Task ResetToBaseFrame()
        => await Run("활성 좌표계 초기화(베이스)", ct => Svc.Rpc!.ResetActiveFrameAsync(_jogTool, 0, ct));

    // 컨트롤러의 현재 활성 작업물 프레임 번호를 클라이언트 추적값에 수동 반영(실측 조회 미지원 펌웨어용).
    private void ApplyAssumedUser()
    {
        Svc.Rpc?.SetAssumedActiveUser(_assumedUser);
        Notify($"컨트롤러 활성 작업물 프레임을 #{_assumedUser}로 설정(클라이언트 추적값). 이제 조그/초기화가 이 값 기준으로 베이스 변환합니다.", false);
    }

    private async Task JogStep(int axis, int sign)
    {
        if (_jogMode != JogMode.Increment) return;   // 연속 모드에선 클릭 무시(포인터 이벤트가 처리)
        if (!Svc.IsConnected) { Notify("연결되지 않았습니다.", true); return; }
        var dis = JogStepDis(axis) * sign;                       // 부호 반영(mm 또는 °)
        var unit = JogAxisIsRotational(axis) ? "°" : "mm";
        var label = $"조그 {JogAxisLabels[axis]}{(sign > 0 ? "+" : "-")} {Math.Abs(dis)}{unit}";
        await Run(label, async ct =>
        {
            if (_jogFrame == JogFrame.Joint)
            {
                // 관절 증분: 현재 관절각에 선택 축 ±dis° 더한 MoveJ (IK 없음 → 특이점 안전).
                var joints = await Svc.Rpc!.GetActualJointPosAsync(ct: ct);
                joints[axis] += dis;
                return await Svc.Rpc!.MoveJAsync(joints, new double[6], tool: _jogTool, vel: _jogVel, ct: ct);
            }
            // 직교 증분: 현재 TCP 앵커에 선택 좌표계 축으로 offset 적용(MoveL). 앵커·이동 공구 동일.
            var curJoints = await Svc.Rpc!.GetActualJointPosAsync(ct: ct);
            var anchor = await Svc.Rpc!.GetTcpPoseInBaseAsync(_jogTool, ct);
            var offset = new double[6];
            offset[axis] = dis;
            int flag = _jogFrame == JogFrame.Tool ? 2 : 1;        // 툴=2, 베이스/작업물=1
            int user = _jogFrame == JogFrame.Workpiece ? _jogUser : 0;
            return await Svc.Rpc!.MoveLAsync(anchor, jointPos: curJoints, tool: _jogTool, user: user,
                                             vel: _jogVel, offsetFlag: flag, offsetPos: offset, ct: ct);
        });
    }

    /// <summary>누름 연속 조그 시작(포인터 다운). Hold 모드에서만 동작. StartJOG는 논블로킹이라 Run 게이트를
    /// 쓰지 않고(매 프레스 완료 토스트 방지), maxDis(연속 상한)까지 이동 후 자동 정지한다.</summary>
    private async Task JogHoldStart(int axis, int sign)
    {
        if (_jogMode != JogMode.Hold) return;
        if (!Svc.IsConnected || _busy || _holding) return;
        _holding = true;
        _holdFrame = _jogFrame;
        var max = JogAxisIsRotational(axis) ? _jogHoldMaxDeg : _jogHoldMaxMm;
        try
        {
            var rc = await Svc.Rpc!.StartJogAsync(_jogFrame, axis + 1, sign > 0 ? 1 : 0, max, _jogVel);
            if (rc != 0)
            {
                _holding = false;
                Notify($"연속 조그 시작 실패 (rc={rc}){FairinoErrorCodes.Suffix(rc)}", true);
            }
        }
        catch (Exception ex)
        {
            _holding = false;
            Notify($"연속 조그 시작 실패: {ex.Message}", true);
        }
    }

    /// <summary>누름 연속 조그 정지(포인터 업/이탈/취소). 시작 시 프레임(_holdFrame)의 StopJOG를 보낸다.</summary>
    private async Task JogHoldStop()
    {
        if (!_holding) return;
        var frame = _holdFrame;
        _holding = false;
        try
        {
            await Svc.StopJogAsync(frame);
        }
        catch (Exception ex)
        {
            Notify($"연속 조그 정지 실패: {ex.Message}", true);
        }
    }

    /// <summary>긴급 정지: 진행 중인 명령을 취소하고 즉시 StopMotion 전송(세마포어 우회).</summary>
    private async Task EmergencyStop()
    {
        _opCts?.Cancel();   // 진행 중 명령의 클라이언트 대기/후속 호출 즉시 중단
        _holding = false;   // 연속 조그 상태 해제(ImmStopJOG가 실제 정지)
        try
        {
            await Svc.ImmStopJogImmediateAsync();   // 진행 중 조그 즉시 정지(ImmStopJOG)
            var rc = await Svc.StopMotionImmediateAsync();
            Notify($"긴급 정지 (rc={rc}){FairinoErrorCodes.Suffix(rc)}", rc != 0);
        }
        catch (Exception ex)
        {
            Notify($"긴급 정지 실패: {ex.Message}", true);
        }
    }

    /// <summary>컨트롤러의 걸린 오류 상태를 해제(ResetAllError). errcode 14(fault)로 조그/이동이 막힐 때 사용.</summary>
    private async Task ResetError()
        => await Run("오류 해제", ct => Svc.ResetErrorAsync(ct));

    /// <summary>서보(로봇) 활성화/비활성화 토글. FAIRINO는 서보 전용 제어가 없어 RobotEnable로 통합된다.</summary>
    private async Task ToggleServo()
    {
        var target = !Svc.IsServoEnabled;
        try
        {
            var rc = await Svc.SetServoEnableAsync(target);
            Notify($"서보 {(target ? "활성화" : "비활성화")} (rc={rc}){FairinoErrorCodes.Suffix(rc)}", rc != 0);
        }
        catch (Exception ex)
        {
            Notify($"서보 전환 실패: {ex.Message}", true);
        }
    }

    private async Task Run(string label, Func<CancellationToken, Task<int>> action)
    {
        if (_busy) return;
        _busy = true;
        _message = null;
        _opCts?.Dispose();
        _opCts = new CancellationTokenSource();
        var ct = _opCts.Token;
        try
        {
            var rc = await action(ct);
            Notify($"{label} 완료 (rc={rc}){FairinoErrorCodes.Suffix(rc)}", rc != 0);
        }
        catch (OperationCanceledException)
        {
            Notify($"{label} 취소됨 (긴급 정지)", true);
        }
        catch (Exception ex)
        {
            Notify($"{label} 실패: {ex.Message}", true);
        }
        finally
        {
            _busy = false;
        }
    }

    private void Notify(string msg, bool error)
    {
        _message = msg;
        _isError = error;
    }

    public void Dispose()
    {
        // 파괴 시 진행 중일 수 있는 증분 이동(MoveL/MoveJ)·연속 조그(StartJOG)를 best-effort 정지.
        if (_holding && Svc.IsConnected) _ = Svc.ImmStopJogImmediateAsync();
        _holding = false;
        if (Svc.IsConnected) _ = Svc.StopMotionImmediateAsync();
        _cts?.Cancel();
        _cts?.Dispose();
        _opCts?.Cancel();
        _opCts?.Dispose();
    }
}
